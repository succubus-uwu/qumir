алг вещ функция нач
    цел i
    цел j
    вещ k
    k := 0.0
    нц для i от 0 до 3
        лит a
        a := "outer"
        нц для j от 0 до 3
            лит b
            b := "inner"
            если j > 1 то
                выход
            все
            k := k + 1.0
        кц
        k := k + 10.0
    кц
    знач := k
кон
