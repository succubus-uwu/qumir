(block
  (fun f () -> string
    (block
      (var знач = (bitcast 0 string))
      (var s = (bitcast 0 string))
      (replace s (own-literal "s12345"))
      (call g s)
      (replace знач (retain (borrow s)))
      (return знач)))
  (fun g ((var s <ref string>))
    (block
      (var a char)
      (= a (call str_symbol_at s 1))
      (replace s (move (call str_concat s (call str_from_unicode a))))
      (return))))