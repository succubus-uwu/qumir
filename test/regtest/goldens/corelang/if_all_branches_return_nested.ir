function <main> () { ; void
  block {
    label: label(0)
    arg imm(1,i64) 
    call tmp(0,i64) = choose 
    arg tmp(0,i64) 
    arg imm(0,i64) 
    call output_int64 
    arg imm(1,ptr to i8) 
    call output_string 
    arg imm(0,i64) 
    call tmp(1,i64) = choose 
    arg tmp(1,i64) 
    arg imm(0,i64) 
    call output_int64 
    arg imm(2,ptr to i8) 
    call output_string 
    jmp label(1) 
  }
  block {
    label: label(1)
    ret 
  }
}
function choose (local(0)) { ; i64
  block {
    label: label(0)
    load tmp(0,i1) = local(0,i1) 
    cmp tmp(0,i1) label(2) label(3) 
  }
  block {
    label: label(2)
    stre local(1,i64) imm(1,i64) 
    jmp label(1) 
  }
  block {
    label: label(3)
    stre local(1,i64) imm(0,i64) 
    jmp label(1) 
  }
  block {
    label: label(1)
    load tmp(1,i64) = local(1,i64) 
    ret tmp(1,i64) 
  }
}
