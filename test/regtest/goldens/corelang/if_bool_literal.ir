function bitoff (local(0), local(1), local(2)) { ; i1
  block {
    label: label(0)
    stre local(3,i1) imm(1,i64) 
    jmp label(1) 
  }
  block {
    label: label(1)
    load tmp(0,i1) = local(3,i1) 
    ret tmp(0,i1) 
  }
}
function touch (local(0)) { ; ptr to u8
  block {
    label: label(0)
    load tmp(0,ptr to u8) = local(0,ptr to u8) 
    stre local(1,ptr to u8) tmp(0,ptr to u8) 
    jmp label(1) 
  }
  block {
    label: label(1)
    load tmp(1,ptr to u8) = local(1,ptr to u8) 
    ret tmp(1,ptr to u8) 
  }
}
function test (local(0), local(1)) { ; i1
  block {
    label: label(0)
    load tmp(0,ptr to u8) = local(0,ptr to u8) 
    load tmp(1,i64) = local(1,i64) 
    arg tmp(0,ptr to u8) 
    arg tmp(1,i64) 
    arg imm(0,i64) 
    call tmp(2,i1) = bitoff 
    stre local(2,i1) tmp(2,i1) 
    load tmp(3,ptr to u8) = local(0,ptr to u8) 
    arg tmp(3,ptr to u8) 
    call tmp(4,ptr to u8) = touch 
    stre local(3,ptr to u8) tmp(4,ptr to u8) 
    cmp imm(1,i64) label(2) label(3) 
  }
  block {
    label: label(2)
    load tmp(5,i1) = local(2,i1) 
    jmp label(3) 
  }
  block {
    label: label(3)
    phi tmp(6,i1) = imm(1,i64) label(0) tmp(5,i1) label(2) 
    stre local(4,i1) tmp(6,i1) 
    jmp label(1) 
  }
  block {
    label: label(1)
    load tmp(7,i1) = local(4,i1) 
    ret tmp(7,i1) 
  }
}
