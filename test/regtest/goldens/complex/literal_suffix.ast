(block
  (use "Комплексные числа")
  (fun <main> void () ()
    (block
      (var z <named компл <struct (re f64) (im f64)>>)
      (= z (: (struct ((re 0) (im 2))) <named компл <struct (re f64) (im f64)>>))
      (seq
        (call output_string "2i: Re=")
        (call output_double (field re (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string "\n"))
      (= z (: (struct ((re 0) (im 3.5))) <named компл <struct (re f64) (im f64)>>))
      (seq
        (call output_string "3.5i: Re=")
        (call output_double (field re (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string "\n"))
      (= z
        (: (struct ((re (+ (field re (: (struct ((re 0) (im 2))) <named компл <struct (re f64) (im f64)>>))
                (field re (: (struct ((re (cast 10 f64)) (im 0))) <named компл <struct (re f64) (im f64)>>))))
              (im (+ (field im (: (struct ((re 0) (im 2))) <named компл <struct (re f64) (im f64)>>))
                (field im (: (struct ((re (cast 10 f64)) (im 0))) <named компл <struct (re f64) (im f64)>>))))))
          <named компл <struct (re f64) (im f64)>>))
      (seq
        (call output_string "2i+10: Re=")
        (call output_double (field re (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string "\n"))
      (= z
        (: (struct ((re (- (* (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>))
                  (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                (* (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>))
                  (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))
              (im (+ (* (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>))
                  (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                (* (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>))
                  (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))))
          <named компл <struct (re f64) (im f64)>>))
      (seq
        (call output_string "i*i: Re=")
        (call output_double (field re (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string "\n")))))