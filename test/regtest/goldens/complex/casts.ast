(block
  (use "Комплексные числа")
  (fun <main> void () ()
    (block
      (var x f64)
      (var y f64)
      (var n i64)
      (var a <named компл>)
      (var b <named компл>)
      (= x 3.5)
      (= a (: (struct ((re x) (im 0))) <named компл>))
      (seq
        (call output_string "float_to_complex Re=")
        (call output_double (field re (: a <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: a <named компл>)) 0 -1)
        (call output_string "\n"))
      (= n 7)
      (= b (: (struct ((re (cast n f64)) (im 0))) <named компл>))
      (seq
        (call output_string "int_to_complex Re=")
        (call output_double (field re (: b <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: b <named компл>)) 0 -1)
        (call output_string "\n"))
      (= y (field re (: a <named компл>)))
      (seq
        (call output_string "complex_to_float=")
        (call output_double y 0 -1)
        (call output_string "\n"))
      (= n (cast (field re (: a <named компл>)) i64))
      (seq
        (call output_string "complex_to_int=")
        (call output_int64 n 0)
        (call output_string "\n")))))