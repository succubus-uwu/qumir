(block
  (use "Комплексные числа")
  (fun <main> void () ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var c <named компл>)
      (= a
        (: (struct ((re (+ (field re (: (struct ((re 1) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re 2) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 2) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 2) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 2) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re 1) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re 2) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 2) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 2) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 2) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))
      (= b
        (: (struct ((re (+ (field re (: (struct ((re 3) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re 3) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))
      (= c
        (: (struct ((re (+ (field re (: a <named компл>)) (field re (: b <named компл>))))
              (im (+ (field im (: a <named компл>)) (field im (: b <named компл>))))))
          <named компл>))
      (seq
        (call output_string "add Re=")
        (call output_double (field re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (field re (: b <named компл>)) (field re (: a <named компл>))))
              (im (- (field im (: b <named компл>)) (field im (: a <named компл>))))))
          <named компл>))
      (seq
        (call output_string "sub Re=")
        (call output_double (field re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (* (field re (: a <named компл>)) (field re (: b <named компл>)))
                (* (field im (: a <named компл>)) (field im (: b <named компл>)))))
              (im (+ (* (field re (: a <named компл>)) (field im (: b <named компл>)))
                (* (field im (: a <named компл>)) (field re (: b <named компл>)))))))
          <named компл>))
      (seq
        (call output_string "mul Re=")
        (call output_double (field re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (/ (+ (* (field re (: b <named компл>)) (field re (: a <named компл>)))
                  (* (field im (: b <named компл>)) (field im (: a <named компл>))))
                (+ (* (field re (: a <named компл>)) (field re (: a <named компл>)))
                  (* (field im (: a <named компл>)) (field im (: a <named компл>))))))
              (im (/ (- (* (field im (: b <named компл>)) (field re (: a <named компл>)))
                  (* (field re (: b <named компл>)) (field im (: a <named компл>))))
                (+ (* (field re (: a <named компл>)) (field re (: a <named компл>)))
                  (* (field im (: a <named компл>)) (field im (: a <named компл>))))))))
          <named компл>))
      (seq
        (call output_string "div Re=")
        (call output_double (field re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: c <named компл>)) 0 -1)
        (call output_string "\n"))
      (= c
        (: (struct ((re (- (field re (: a <named компл>)))) (im (- (field im (: a <named компл>))))))
          <named компл>))
      (seq
        (call output_string "neg Re=")
        (call output_double (field re (: c <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: c <named компл>)) 0 -1)
        (call output_string "\n")))))