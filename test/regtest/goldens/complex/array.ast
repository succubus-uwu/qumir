(block
  (use "Комплексные числа")
  (fun <main> ()
    (block
      (var arr <array <named компл> 1> [0 2])
      (var j i64)
      (for j
        0
        2
        1
        (block
          (= arr
            [j]
            (: (struct ((re (+ (field (: (struct ((re (cast j f64)) (im 0))) <named компл>) re)
                    (field (: (struct ((re 0) (im 1))) <named компл>) re)))
                  (im (+ (field (: (struct ((re (cast j f64)) (im 0))) <named компл>) im)
                    (field (: (struct ((re 0) (im 1))) <named компл>) im)))))
              <named компл>))))
      (for j
        0
        2
        1
        (block
          (block
            (call output_string "arr[")
            (call output_int64 j 0)
            (call output_string "] Re=")
            (call output_double (field (: (index arr j) <named компл>) re) 0 -1)
            (call output_string " Im=")
            (call output_double (field (: (index arr j) <named компл>) im) 0 -1)
            (call output_string "\n"))))
      (cleanup-exit (return) (destroy arr)))))