(block
  (use "Комплексные числа")
  (fun main void () ()
    (block
      (var z <named компл <struct (re f64) (im f64)>>)
      (var re f64)
      (var im f64)
      (call make_by_ref 4 6 (: z <named компл <struct (re f64) (im f64)>>))
      (call split (: z <named компл <struct (re f64) (im f64)>>) re im)
      (seq
        (call output_string "made Re=")
        (call output_double re 0 -1)
        (call output_string " Im=")
        (call output_double im 0 -1)
        (call output_string "\n"))
      (call
        add_in_place
        (: z <named компл <struct (re f64) (im f64)>>)
        (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>))
      (seq
        (call output_string "updated Re=")
        (call output_double (field re (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл <struct (re f64) (im f64)>>)) 0 -1)
        (call output_string "\n"))))
  (fun split void ((var z <named компл <struct (re f64) (im f64)> (readable)>)
      (var re <ref <f64 (mutable)>>)
      (var im <ref <f64 (mutable)>>)) ()
    (block
      (= re (field re (: z <named компл <struct (re f64) (im f64)> (readable)>)))
      (= im (field im (: z <named компл <struct (re f64) (im f64)> (readable)>)))))
  (fun make_by_ref void ((var re <f64 (readable)>)
      (var im <f64 (readable)>)
      (var z <ref <named компл <struct (re f64) (im f64)> (mutable)>>)) ()
    (block
      (= z
        (: (struct ((re (+ (field re (: (struct ((re re) (im 0))) <named компл <struct (re f64) (im f64)>>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))))
                    <named компл <struct (re f64) (im f64)>>))))
              (im (+ (field im (: (struct ((re re) (im 0))) <named компл <struct (re f64) (im f64)>>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field im (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл <struct (re f64) (im f64)>>))
                            (field re (: (struct ((re 0) (im 1))) <named компл <struct (re f64) (im f64)>>)))))))
                    <named компл <struct (re f64) (im f64)>>))))))
          <named компл <struct (re f64) (im f64)>>))))
  (fun add_in_place void ((var z <ref <named компл <struct (re f64) (im f64)>>>)
      (var delta <named компл <struct (re f64) (im f64)> (readable)>)) ()
    (block
      (= z
        (: (struct ((re (+ (field re z) (field re (: delta <named компл <struct (re f64) (im f64)> (readable)>))))
              (im (+ (field im z) (field im (: delta <named компл <struct (re f64) (im f64)> (readable)>))))))
          <named компл <struct (re f64) (im f64)>>)))))