(block
  (use "Комплексные числа")
  (fun main void () ()
    (block
      (var z <named компл>)
      (var re f64)
      (var im f64)
      (call make_by_ref 4 6 (: z <named компл>))
      (call split (: z <named компл>) re im)
      (seq
        (call output_string "made Re=")
        (call output_double re 0 -1)
        (call output_string " Im=")
        (call output_double im 0 -1)
        (call output_string "\n"))
      (call add_in_place (: z <named компл>) (: (struct ((re 0) (im 1))) <named компл>))
      (seq
        (call output_string "updated Re=")
        (call output_double (field re (: z <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: z <named компл>)) 0 -1)
        (call output_string "\n"))))
  (fun split void ((var z <named компл>)
      (var re <ref <f64 (mutable)>>)
      (var im <ref <f64 (mutable)>>)) ()
    (block
      (= re (field re (: z <named компл>)))
      (= im (field im (: z <named компл>)))))
  (fun make_by_ref void ((var re f64)
      (var im f64)
      (var z <ref <named компл>>)) ()
    (block
      (= z
        (: (struct ((re (+ (field re (: (struct ((re re) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re re) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))))
  (fun add_in_place void ((var z <ref <named компл>>)
      (var delta <named компл>)) ()
    (block
      (= z
        (: (struct ((re (+ (field re z) (field re (: delta <named компл>))))
              (im (+ (field im z) (field im (: delta <named компл>))))))
          <named компл>)))))