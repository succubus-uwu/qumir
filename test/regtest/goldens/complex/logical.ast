(block
  (use "Комплексные числа")
  (fun <main> void () ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (var same bool)
      (var different bool)
      (= a
        (: (struct ((re (+ (field re (: (struct ((re 2) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re 3) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 3) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 3) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 3) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re 2) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re 3) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 3) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 3) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 3) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))
      (= b
        (: (struct ((re (+ (field re (: (struct ((re 2) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re 2) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re 4) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re 4) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))
      (= same
        (&& (== (field re (: a <named компл>)) (field re (: a <named компл>)))
          (== (field im (: a <named компл>)) (field im (: a <named компл>)))))
      (= different
        (|| (!= (field re (: a <named компл>)) (field re (: b <named компл>)))
          (!= (field im (: a <named компл>)) (field im (: b <named компл>)))))
      (seq
        (call output_string "and=")
        (call output_bool (&& same different))
        (call output_string "\n"))
      (seq
        (call output_string "or=")
        (call
          output_bool
          (|| same
            (&& (== (field re (: a <named компл>)) (field re (: b <named компл>)))
              (== (field im (: a <named компл>)) (field im (: b <named компл>))))))
        (call output_string "\n"))
      (seq
        (call output_string "not=")
        (call
          output_bool
          (! (&& (== (field re (: a <named компл>)) (field re (: b <named компл>)))
              (== (field im (: a <named компл>)) (field im (: b <named компл>))))))
        (call output_string "\n")))))