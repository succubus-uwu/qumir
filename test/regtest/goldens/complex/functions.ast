(block
  (use "Комплексные числа")
  (fun main void () ()
    (block
      (var a <named компл>)
      (var b <named компл>)
      (= a (: (call make_complex 2 5) <named компл>))
      (seq
        (call output_string "arg Re=")
        (call output_double (call real_part (: a <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (call imag_part (: a <named компл>)) 0 -1)
        (call output_string "\n"))
      (= b
        (: (call add_twice (: a <named компл>) (: (struct ((re 0) (im 1))) <named компл>)) <named компл>))
      (seq
        (call output_string "return Re=")
        (call output_double (field re (: b <named компл>)) 0 -1)
        (call output_string " Im=")
        (call output_double (field im (: b <named компл>)) 0 -1)
        (call output_string "\n"))))
  (fun real_part f64 ((var z <named компл>)) ()
    (block
      (var $$return f64)
      (= $$return (field re (: z <named компл>)))))
  (fun imag_part f64 ((var z <named компл>)) ()
    (block
      (var $$return f64)
      (= $$return (field im (: z <named компл>)))))
  (fun make_complex <named компл> ((var re f64)
      (var im f64)) ()
    (block
      (var $$return <named компл>)
      (= $$return
        (: (struct ((re (+ (field re (: (struct ((re re) (im 0))) <named компл>))
                (field re
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))
              (im (+ (field im (: (struct ((re re) (im 0))) <named компл>))
                (field im
                  (: (struct ((re (- (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))))
                        (im (+ (* (field re (: (struct ((re im) (im 0))) <named компл>))
                            (field im (: (struct ((re 0) (im 1))) <named компл>)))
                          (* (field im (: (struct ((re im) (im 0))) <named компл>))
                            (field re (: (struct ((re 0) (im 1))) <named компл>)))))))
                    <named компл>))))))
          <named компл>))))
  (fun add_twice <named компл> ((var a <named компл>)
      (var b <named компл>)) ()
    (block
      (var $$return <named компл>)
      (= $$return
        (: (struct ((re (+ (field re
                  (: (struct ((re (+ (field re (: a <named компл>)) (field re (: b <named компл>))))
                        (im (+ (field im (: a <named компл>)) (field im (: b <named компл>))))))
                    <named компл>))
                (field re (: b <named компл>))))
              (im (+ (field im
                  (: (struct ((re (+ (field re (: a <named компл>)) (field re (: b <named компл>))))
                        (im (+ (field im (: a <named компл>)) (field im (: b <named компл>))))))
                    <named компл>))
                (field im (: b <named компл>))))))
          <named компл>)))))