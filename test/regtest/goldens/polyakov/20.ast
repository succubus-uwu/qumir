(block
  (fun |Сортировка строк| ()
    (block
      (var i i64)
      (var j i64)
      (var N i64)
      (= N 10)
      (var S <array string 1> [1 N])
      (var s1 = (bitcast 0 string))
      (replace (index S 1) (own-literal "AAAbc"))
      (replace (index S 2) (own-literal "123_33123"))
      (replace (index S 3) (own-literal "-1233)1"))
      (replace (index S 4) (own-literal "Вася"))
      (replace (index S 5) (own-literal "петя"))
      (replace (index S 6) (own-literal "Иван Иванович"))
      (replace (index S 7) (own-literal "Антон"))
      (replace (index S 8) (own-literal "John"))
      (replace (index S 9) (own-literal "   01"))
      (replace (index S 10) (own-literal "Нет"))
      (for i
        1
        (- N 1)
        1
        (block
          (for j
            (- N 1)
            i
            (- 1)
            (block
              (if
                (< (call str_compare (index S (+ j 1)) (index S j)) 0)
                (block
                  (replace s1 (retain (borrow (index S j))))
                  (replace (index S j) (retain (borrow (index S (+ j 1)))))
                  (replace (index S (+ j 1)) (retain (borrow s1)))))))))
      (for i 1 N 1 (block (block (call output_string (index S i)) (call output_string "\n"))))
      (return))))