(block
  (fun |Сортировка строк| ()
    (block
      (var i i64)
      (var j i64)
      (var N i64)
      (= N 10)
      (var S <array string 1> [1 N])
      (var s1 string)
      (= S [1] "AAAbc")
      (= S [2] "123_33123")
      (= S [3] "-1233)1")
      (= S [4] "Вася")
      (= S [5] "петя")
      (= S [6] "Иван Иванович")
      (= S [7] "Антон")
      (= S [8] "John")
      (= S [9] "   01")
      (= S [10] "Нет")
      (for i
        1
        (- N 1)
        1
        (block
          (for j
            (- N 1)
            i
            (- 1)
            (block
              (if
                (< (call str_compare (index S (+ j 1)) (index S j)) 0)
                (block
                  (= s1 (index S j))
                  (= S [j] (index S (+ j 1)))
                  (= S [(+ j 1)] s1)))))))
      (for i 1 N 1 (block (seq (call output_string (index S i)) (call output_string "\n")))))))