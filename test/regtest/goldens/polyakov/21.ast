(block
  (fun |Замена всех| ()
    (block
      (var s = (bitcast 0 string))
      (replace s (own-literal "12.12.12"))
      (replace s (move (call replaceBad s "12" "A12B")))
      (block
        (call output_string s))
      (return)))
  (fun replaceBad ((var s0 string)
      (var sOld string)
      (var sNew string)) -> string
    (block
      (var знач = (bitcast 0 string))
      (var s = (bitcast 0 string))
      (replace s (retain (borrow s0)))
      (var p i64)
      (var len i64)
      (= len (call длин sOld))
      (= p (call позиция sOld s))
      (while
        (> p 0)
        (block
          (call удалить s p len)
          (call вставить sNew s p)
          (= p (call |позиция после| (+ p (call длин sNew)) sOld s))))
      (replace знач (retain (borrow s)))
      (return знач))))