(block
  (fun |Замена всех| void () ()
    (block
      (var s string)
      (= s "12.12.12")
      (= s (call replaceBad s "12" "A12B"))
      (seq
        (call output_string s))))
  (fun replaceBad string ((var s0 string)
      (var sOld string)
      (var sNew string)) ()
    (block
      (var $$return string)
      (var s string)
      (= s s0)
      (var p i64)
      (var len i64)
      (= len (call длин sOld))
      (= p (call позиция sOld s))
      (while
        (> p 0)
        (block
          (call удалить s p len)
          (call вставить sNew s p)
          (= p (call |позиция после| (+ p (call длин sNew)) sOld s))))
      (= $$return s))))