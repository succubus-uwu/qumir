(block
  (fun Массив void () ()
    (block
      (var i i64)
      (var N i64)
      (= N 10)
      (seq
        (var $$A_lbound0 i64)
        (var $$A_dimsize0 i64)
        (var $$A_mulacc0 i64)
        (= $$A_lbound0 1)
        (= $$A_dimsize0 (+ (- N 1) 1))
        (= $$A_mulacc0 (* 1 $$A_dimsize0))
        (var A <array i64 1>))
      (for i 1 N 1 (block (= A [i] (+ 180 (* i i)))))
      (var count i64)
      (= count 0)
      (var sum i64)
      (= sum 0)
      (for i
        1
        N
        1
        (block
          (cond (&& (< 180 (index i A)) (< (index i A) 190)) (block (= count (+ count 1)) (= sum (+ sum (index i A)))))))
      (seq
        (call output_int64 count 0)
        (call output_symbol (cast 32 char))
        (call output_int64 sum 0)
        (call output_string "\n")))))