(block
  (fun Массив ()
    (block
      (var i i64)
      (var N i64)
      (= N 10)
      (var A <array i64 1> [1 N])
      (for i 1 N 1 (block (= A [i] (+ 180 (* i i)))))
      (var count i64)
      (= count 0)
      (var sum i64)
      (= sum 0)
      (for i
        1
        N
        1
        (block
          (if (&& (< 180 (index A i)) (< (index A i) 190)) (block (= count (+ count 1)) (= sum (+ sum (index A i)))))))
      (block
        (call output_int64 count 0)
        (call output_symbol (cast 32 char))
        (call output_int64 sum 0)
        (call output_string "\n"))
      (cleanup-exit (return) (destroy A)))))