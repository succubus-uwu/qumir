(block
  (fun |Замена а на б| void () ()
    (block
      (var s string)
      (= s "ABCDабсвайЙЙ")
      (var i i64)
      (for i
        1
        (call длин s)
        1
        (block
          (cond
            (== (call str_symbol_at s i) (cast 1072 char))
            (block
              (= s (call str_replace_sym s (cast 1073 char) i))))))
      (seq
        (call output_string s)))))