(block
  (fun |Замена а на б| ()
    (block
      (var s string)
      (= s "ABCDабсвайЙЙ")
      (var i i64)
      (for i
        1
        (call длин s)
        1
        (block
          (if (== (call str_symbol_at s i) (cast 1072 char)) (block (= s (call str_replace_sym s (cast 1073 char) i))))))
      (seq
        (call output_string s)))))