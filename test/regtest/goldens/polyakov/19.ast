(block
  (fun ЫШЧО ()
    (block
      (var word string)
      (= word "...")
      (call TumbaWords "ЫШЧО" word 0)))
  (fun TumbaWords ((var A string)
      (var w0 string)
      (var N i64))
    (block
      (if (== N (call длин w0)) (block (seq (call output_string w0) (call output_string "\n")) break))
      (var i i64)
      (var w string)
      (= w (call str_slice w0 1 (call длин w0)))
      (for i
        1
        (call длин A)
        1
        (block
          (= w (call str_replace_sym w (call str_symbol_at A i) (+ N 1)))
          (call TumbaWords A w (+ N 1)))))))