(block
  (fun binSearch void () ()
    (block
      (var N i64)
      (= N 5)
      (seq
        (var $$A_lbound0 i64)
        (var $$A_dimsize0 i64)
        (var $$A_mulacc0 i64)
        (= $$A_lbound0 1)
        (= $$A_dimsize0 (+ (- N 1) 1))
        (= $$A_mulacc0 (* 1 $$A_dimsize0))
        (var A <array i64 1>))
      (var i i64)
      (= A [1] 1)
      (= A [2] 2)
      (= A [3] 3)
      (= A [4] 7)
      (= A [5] 10)
      (var X i64)
      (= X 7)
      (var L i64)
      (var R i64)
      (var c i64)
      (= L 1)
      (= R (+ N 1))
      (while (< L (- R 1)) (block (= c (call div (+ L R) 2)) (cond (< X (index c A)) (block (= R c)) (block (= L c)))))
      (cond
        (== (index L A) X)
        (block
          (seq
            (call output_string "A[")
            (call output_int64 L 0)
            (call output_string "]=")
            (call output_int64 X 0)))
        (block
          (seq
            (call output_string "Не нашли!")))))))