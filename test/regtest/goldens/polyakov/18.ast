(block
  (fun |Замена всех| ()
    (block
      (var s string)
      (= s "12.12.12")
      (call replaceAll s "12" "A12B")
      (seq
        (call output_string s))))
  (fun replaceAll ((var s <ref string>)
      (var wOld string)
      (var wNew string))
    (block
      (var res string)
      (var p i64)
      (var len i64)
      (= len (call длин wOld))
      (= res "")
      (while
        (> (call длин s) 0)
        (block
          (= p (call позиция wOld s))
          (if (< p 0) (block (= res (call str_concat res s)) break))
          (if (> p 1) (block (= res (call str_concat res (call str_slice s 1 (- p 1))))))
          (= res (call str_concat res wNew))
          (if
            (> (+ p len) (call длин s))
            (block
              (= s ""))
            (block
              (= s (call str_slice s (+ p len) (call длин s)))))))
      (= s res))))