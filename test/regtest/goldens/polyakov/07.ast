(block
  (fun <main> ()
    (block
      (var a i64)
      (= a 10)
      (var b i64)
      (= b 11)
      (if
        (> a b)
        (block
          (seq
            (call output_string "Андрей старше")))
        (block
          (if
            (== a b)
            (block
              (seq
                (call output_string "Одного возраста")))
            (block
              (seq
                (call output_string "Борис старше")))))))))