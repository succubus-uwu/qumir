(block
  (var N i64)
  (= N 5)
  (var A <array i64 1> [1 N])
  (fun |Быстрая сортировка| void () ()
    (block
      (var i i64)
      (= A [1] 3)
      (= A [2] 1)
      (= A [3] 10)
      (= A [4] 7)
      (= A [5] 2)
      (call qSort 1 5)
      (for i 1 N 1 (block (seq (call output_int64 (index i A) 0) (call output_symbol (cast 32 char)))))))
  (fun qSort void ((var nStart i64)
      (var nEnd i64)) ()
    (block
      (var L i64)
      (var R i64)
      (var c i64)
      (var X i64)
      (cond (>= nStart nEnd) (block break))
      (= L nStart)
      (= R nEnd)
      (= X (index (call div (+ L R) 2) A))
      (while
        (<= L R)
        (block
          (while (< (index L A) X) (block (= L (+ L 1))))
          (while (> (index R A) X) (block (= R (- R 1))))
          (cond (<= L R) (block (= c (index L A)) (= A [L] (index R A)) (= A [R] c) (= L (+ L 1)) (= R (- R 1))))))
      (call qSort nStart R)
      (call qSort L nEnd))))