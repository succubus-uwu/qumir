(block
  (var N i64)
  (= N 5)
  (var A <array i64 1> [1 N])
  (fun |Быстрая сортировка| ()
    (block
      (var i i64)
      (= A [1] 3)
      (= A [2] 1)
      (= A [3] 10)
      (= A [4] 7)
      (= A [5] 2)
      (call qSort 1 5)
      (for i 1 N 1 (block (block (call output_int64 (index A i) 0) (call output_symbol (cast 32 char)))))
      (cleanup-exit (return))))
  (fun qSort ((var nStart i64)
      (var nEnd i64))
    (block
      (var L i64)
      (var R i64)
      (var c i64)
      (var X i64)
      (if (>= nStart nEnd) (block (cleanup-exit (return))))
      (= L nStart)
      (= R nEnd)
      (= X (index A (call div (+ L R) 2)))
      (while
        (<= L R)
        (block
          (while (< (index A L) X) (block (= L (+ L 1))))
          (while (> (index A R) X) (block (= R (- R 1))))
          (if (<= L R) (block (= c (index A L)) (= A [L] (index A R)) (= A [R] c) (= L (+ L 1)) (= R (- R 1))))))
      (call qSort nStart R)
      (call qSort L nEnd)
      (cleanup-exit (return))))
  (cleanup-global (destroy A)))