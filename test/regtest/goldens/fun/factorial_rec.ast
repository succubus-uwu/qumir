(block
  (fun цикл () -> i64
    (block
      (var знач i64)
      (var ф i64)
      (var i i64)
      (= ф 0)
      (for i 1 1000 1 (block (= ф (call факториал 13))))
      (= знач ф)))
  (fun факториал ((var число i64)) -> i64
    (block
      (var знач i64)
      (var i i64)
      (if
        (== число 1)
        (block
          (= знач 1))
        (block
          (= знач (* число (call факториал (- число 1)))))))))