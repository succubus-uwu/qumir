(block
  (fun тест_логика_строки_символы () -> i64
    (block
      (var знач i64)
      (var s1 = (bitcast 0 string))
      (var s2 = (bitcast 0 string))
      (var ch1 char)
      (var ch2 char)
      (replace s1 (own-literal "alpha"))
      (replace s2 (own-literal "alpha"))
      (= ch1 (cast 97 char))
      (= ch2 (cast 122 char))
      (var счет i64)
      (= счет 0)
      (if (== (call str_compare s1 s2) 0) (block (= счет (+ счет 1))))
      (if (== (call str_compare s1 (call str_from_unicode ch1)) 0) (block (= счет (+ счет 1000))))
      (if (== ch1 (cast 97 char)) (block (= счет (+ счет 1))))
      (if (!= (call str_compare s1 s2) 0) (block (= счет (+ счет 1000))))
      (if (!= ch1 ch2) (block (= счет (+ счет 1))))
      (if (!= ch2 (cast 122 char)) (block (= счет (+ счет 1000))))
      (if (< (call str_compare s1 "beta") 0) (block (= счет (+ счет 1))))
      (if (<= (call str_compare s2 "alpha") 0) (block (= счет (+ счет 1))))
      (if (> (call str_compare "beta" s1) 0) (block (= счет (+ счет 1))))
      (if (>= (call str_compare "alpha" s2) 0) (block (= счет (+ счет 1))))
      (if (< ch1 ch2) (block (= счет (+ счет 1))))
      (if (> ch2 ch1) (block (= счет (+ счет 1))))
      (if (<= ch1 (cast 97 char)) (block (= счет (+ счет 1))))
      (if (>= ch2 (cast 122 char)) (block (= счет (+ счет 1))))
      (= знач счет)
      (return знач))))