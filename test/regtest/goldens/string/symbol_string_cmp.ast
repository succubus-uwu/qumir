(block
  (fun тест_сравнение_символ_строка () -> i64
    (block
      (var знач i64)
      (var c char)
      (var s string)
      (= c (cast 97 char))
      (= s (call str_from_unicode (cast 97 char)))
      (var r i64)
      (= r 0)
      (if (== (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (if (!= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1000))))
      (if (<= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (if (>= (call str_compare (call str_from_unicode c) s) 0) (block (= r (+ r 1))))
      (if (< c (cast 98 char)) (block (= r (+ r 1))))
      (if (> c (cast 96 char)) (block (= r (+ r 1))))
      (= знач r))))