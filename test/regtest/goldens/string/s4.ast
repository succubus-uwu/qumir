(block
  (fun main () -> string
    (block
      (var знач = (bitcast 0 string))
      (var s = (bitcast 0 string))
      (replace s (move (call str_concat "11 " "10")))
      (replace s (move (call ф 10)))
      (replace знач (retain (borrow s)))
      (return знач)))
  (fun ф ((var k i64)) -> string
    (block
      (var знач = (bitcast 0 string))
      (var стр = (bitcast 0 string))
      (var i i64)
      (var j i64)
      (replace стр (own-literal "ыыы"))
      (replace знач (retain (borrow стр)))
      (= j 0)
      (for i 0 10 1 (block (= j (+ j 1))))
      (return знач))))