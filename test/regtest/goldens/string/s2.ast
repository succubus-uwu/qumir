(block
  (fun ф () -> string
    (block
      (var знач = (bitcast 0 string))
      (var s1 = (bitcast 0 string))
      (var s2 = (bitcast 0 string))
      (var s3 = (bitcast 0 string))
      (replace s3 (own-literal "a "))
      (replace s2 (own-literal "b "))
      (replace s1 (own-literal "ыыы"))
      (replace s1 (move (call str_concat (call str_concat s1 s2) s3)))
      (replace знач (retain (borrow s1)))
      (return знач))))