(block
  (fun тест_неравенство_символ_строка () -> i64
    (block
      (var знач i64)
      (var x char)
      (var t = (bitcast 0 string))
      (= x (cast 98 char))
      (replace t (move (call str_from_unicode (cast 99 char))))
      (var r i64)
      (= r 0)
      (if (!= (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1))))
      (if (== (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1000))))
      (if (< (call str_compare (call str_from_unicode x) t) 0) (block (= r (+ r 1))))
      (if (> (call str_compare t (call str_from_unicode x)) 0) (block (= r (+ r 1))))
      (= знач r)
      (return знач))))