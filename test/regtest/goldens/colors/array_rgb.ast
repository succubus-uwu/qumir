(block
  (use "Цвета")
  (fun <main> void () ()
    (block
      (var палитра <array <named цвет> 1> [1 4])
      (var i i64)
      (var r i64)
      (var g i64)
      (var b i64)
      (= палитра
        [1]
        (: (cast (| (| (| (<< (& 255 255) 24) (<< (& 255 255) 16)) (<< (& 0 255) 8)) (& 0 255)) <named цвет>)
          <named цвет>))
      (= палитра
        [2]
        (: (cast (| (| (| (<< (& 255 255) 24) (<< (& 0 255) 16)) (<< (& 255 255) 8)) (& 0 255)) <named цвет>)
          <named цвет>))
      (= палитра
        [3]
        (: (cast (| (| (| (<< (& 255 255) 24) (<< (& 0 255) 16)) (<< (& 0 255) 8)) (& 255 255)) <named цвет>)
          <named цвет>))
      (= палитра
        [4]
        (: (cast (| (| (| (<< (& 255 255) 24) (<< (& 128 255) 16)) (<< (& 64 255) 8)) (& 32 255)) <named цвет>)
          <named цвет>))
      (for i
        1
        4
        1
        (block
          (block
            (var $$color_decompose_rgb_0 i64)
            (= $$color_decompose_rgb_0 (cast (: (index i палитра) <named цвет>) i64))
            (= r (& (>> $$color_decompose_rgb_0 16) 255))
            (= g (& (>> $$color_decompose_rgb_0 8) 255))
            (= b (& $$color_decompose_rgb_0 255)))
          (seq
            (call output_int64 r 0)
            (call output_symbol (cast 32 char))
            (call output_int64 g 0)
            (call output_symbol (cast 32 char))
            (call output_int64 b 0)
            (call output_string "\n")))))))