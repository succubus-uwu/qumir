(block
  (fun <main> void () ()
    (block
      (var Nx i64)
      (var Ny i64)
      (var Nz i64)
      (= Nx 8)
      (= Ny 8)
      (= Nz 8)
      (var pi f64)
      (= pi 3.14159)
      (var h f64)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (var h2 f64)
      (= h2 (* h h))
      (seq
        (var $$u_lbound2 i64)
        (var $$u_dimsize2 i64)
        (var $$u_mulacc2 i64)
        (= $$u_lbound2 0)
        (= $$u_dimsize2 (+ (- (- Nz 1) 0) 1))
        (= $$u_mulacc2 (* 1 $$u_dimsize2))
        (var $$u_lbound1 i64)
        (var $$u_dimsize1 i64)
        (var $$u_mulacc1 i64)
        (= $$u_lbound1 0)
        (= $$u_dimsize1 (+ (- (- Ny 1) 0) 1))
        (= $$u_mulacc1 (* (* 1 $$u_dimsize2) $$u_dimsize1))
        (var $$u_lbound0 i64)
        (var $$u_dimsize0 i64)
        (var $$u_mulacc0 i64)
        (= $$u_lbound0 0)
        (= $$u_dimsize0 (+ (- (- Nx 1) 0) 1))
        (= $$u_mulacc0 (* (* (* 1 $$u_dimsize2) $$u_dimsize1) $$u_dimsize0))
        (var u <array f64 3>))
      (seq
        (var $$un_lbound2 i64)
        (var $$un_dimsize2 i64)
        (var $$un_mulacc2 i64)
        (= $$un_lbound2 0)
        (= $$un_dimsize2 (+ (- (- Nz 1) 0) 1))
        (= $$un_mulacc2 (* 1 $$un_dimsize2))
        (var $$un_lbound1 i64)
        (var $$un_dimsize1 i64)
        (var $$un_mulacc1 i64)
        (= $$un_lbound1 0)
        (= $$un_dimsize1 (+ (- (- Ny 1) 0) 1))
        (= $$un_mulacc1 (* (* 1 $$un_dimsize2) $$un_dimsize1))
        (var $$un_lbound0 i64)
        (var $$un_dimsize0 i64)
        (var $$un_mulacc0 i64)
        (= $$un_lbound0 0)
        (= $$un_dimsize0 (+ (- (- Nx 1) 0) 1))
        (= $$un_mulacc0 (* (* (* 1 $$un_dimsize2) $$un_dimsize1) $$un_dimsize0))
        (var un <array f64 3>))
      (seq
        (var $$f_lbound2 i64)
        (var $$f_dimsize2 i64)
        (var $$f_mulacc2 i64)
        (= $$f_lbound2 0)
        (= $$f_dimsize2 (+ (- (- Nz 1) 0) 1))
        (= $$f_mulacc2 (* 1 $$f_dimsize2))
        (var $$f_lbound1 i64)
        (var $$f_dimsize1 i64)
        (var $$f_mulacc1 i64)
        (= $$f_lbound1 0)
        (= $$f_dimsize1 (+ (- (- Ny 1) 0) 1))
        (= $$f_mulacc1 (* (* 1 $$f_dimsize2) $$f_dimsize1))
        (var $$f_lbound0 i64)
        (var $$f_dimsize0 i64)
        (var $$f_mulacc0 i64)
        (= $$f_lbound0 0)
        (= $$f_dimsize0 (+ (- (- Nx 1) 0) 1))
        (= $$f_mulacc0 (* (* (* 1 $$f_dimsize2) $$f_dimsize1) $$f_dimsize0))
        (var f <array f64 3>))
      (var i i64)
      (var j i64)
      (var k i64)
      (var x f64)
      (var y f64)
      (var z f64)
      (var err f64)
      (var uex f64)
      (var diff f64)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= u [i j k] 0)
                  (= un [i j k] 0)
                  (= f [i j k] (* (* (* (* (* 3 pi) pi) (call sin (* pi x))) (call sin (* pi y))) (call sin (* pi z))))))))))
      (var it i64)
      (var iters i64)
      (= iters 2000)
      (var tol f64)
      (= tol 0.001)
      (for it
        0
        (- iters 1)
        1
        (block
          (for i
            1
            (- Nx 2)
            1
            (block
              (for j
                1
                (- Ny 2)
                1
                (block
                  (for k
                    1
                    (- Nz 2)
                    1
                    (block
                      (= un
                        [i
                          j
                          k]
                        (/ (+ (+ (+ (+ (+ (+ (index [(+ i 1) j k] u) (index [(- i 1) j k] u)) (index [i (+ j 1) k] u))
                                  (index [i (- j 1) k] u))
                                (index [i j (+ k 1)] u))
                              (index [i j (- k 1)] u))
                            (* h2 (index [i j k] f)))
                          6))))))))
          (for i
            1
            (- Nx 2)
            1
            (block
              (for j 1 (- Ny 2) 1 (block (for k 1 (- Nz 2) 1 (block (= u [i j k] (index [i j k] un))))))))
          (= err 0)
          (for i
            0
            (- Nx 1)
            1
            (block
              (= x (* (cast i f64) h))
              (for j
                0
                (- Ny 1)
                1
                (block
                  (= y (* (cast j f64) h))
                  (for k
                    0
                    (- Nz 1)
                    1
                    (block
                      (= z (* (cast k f64) h))
                      (= uex (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))
                      (= diff (let (($$value (- (index [i j k] u) uex))) (if (< $$value 0) (- $$value) $$value)))
                      (= err (let (($$left err) ($$right diff)) (if (> $$left $$right) $$left $$right)))))))))
          (cond (< err tol) (block break))))
      (= err 0)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= uex (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))
                  (= diff (let (($$value (- (index [i j k] u) uex))) (if (< $$value 0) (- $$value) $$value)))
                  (= err (let (($$left err) ($$right diff)) (if (> $$left $$right) $$left $$right)))))))))
      (seq
        (call output_string "Poisson3D: N=")
        (call output_int64 Nx 0)
        (call output_string " max|u-uex|=")
        (call output_double err 8 8)
        (call output_symbol (cast 10 char)))
      (cond (< err tol) (block (seq (call output_string "OK\n"))) (block (seq (call output_string "FAIL\n")))))))