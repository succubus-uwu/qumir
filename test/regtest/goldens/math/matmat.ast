(block
  (fun main void () ()
    (block
      (var n i64)
      (var i i64)
      (var j i64)
      (var k i64)
      (= n 16)
      (seq
        (var $$A_lbound1 i64)
        (var $$A_dimsize1 i64)
        (var $$A_mulacc1 i64)
        (= $$A_lbound1 0)
        (= $$A_dimsize1 (+ (- (- n 1) 0) 1))
        (= $$A_mulacc1 (* 1 $$A_dimsize1))
        (var $$A_lbound0 i64)
        (var $$A_dimsize0 i64)
        (var $$A_mulacc0 i64)
        (= $$A_lbound0 0)
        (= $$A_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$A_mulacc0 (* (* 1 $$A_dimsize1) $$A_dimsize0))
        (var A <array f64 2>))
      (seq
        (var $$B_lbound1 i64)
        (var $$B_dimsize1 i64)
        (var $$B_mulacc1 i64)
        (= $$B_lbound1 0)
        (= $$B_dimsize1 (+ (- (- n 1) 0) 1))
        (= $$B_mulacc1 (* 1 $$B_dimsize1))
        (var $$B_lbound0 i64)
        (var $$B_dimsize0 i64)
        (var $$B_mulacc0 i64)
        (= $$B_lbound0 0)
        (= $$B_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$B_mulacc0 (* (* 1 $$B_dimsize1) $$B_dimsize0))
        (var B <array f64 2>))
      (seq
        (var $$C_lbound1 i64)
        (var $$C_dimsize1 i64)
        (var $$C_mulacc1 i64)
        (= $$C_lbound1 0)
        (= $$C_dimsize1 (+ (- (- n 1) 0) 1))
        (= $$C_mulacc1 (* 1 $$C_dimsize1))
        (var $$C_lbound0 i64)
        (var $$C_dimsize0 i64)
        (var $$C_mulacc0 i64)
        (= $$C_lbound0 0)
        (= $$C_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$C_mulacc0 (* (* 1 $$C_dimsize1) $$C_dimsize0))
        (var C <array f64 2>))
      (var sum f64)
      (var err f64)
      (var absv f64)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (cond (<= j i) (block (= A [i j] 1)) (block (= A [i j] 0)))
              (cond (>= j i) (block (= B [i j] 1)) (block (= B [i j] 0)))))))
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (= sum 0)
              (for k 0 (- n 1) 1 (block (= sum (+ sum (* (index [i k] A) (index [k j] B))))))
              (= C [i j] sum)))))
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (cond
                (< i j)
                (block
                  (= err (- (index [i j] C) (+ (cast i f64) 1))))
                (block
                  (= err (- (index [i j] C) (+ (cast j f64) 1)))))
              (= absv err)
              (cond (< absv 0) (block (= absv (- absv))))
              (= res_l2_sq (+ res_l2_sq (* err err)))
              (cond (> absv res_inf) (block (= res_inf absv)))))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "matmat: ||e||_2^2 = ")
        (call output_double res_l2_sq 0 -1)
        (call output_string "\n"))
      (seq
        (call output_string "matmat: ||e||_2    = ")
        (call output_double res_l2 0 -1)
        (call output_string "\n"))
      (seq
        (call output_string "matmat: ||e||_inf  = ")
        (call output_double res_inf 0 -1)
        (call output_string "\n")))))