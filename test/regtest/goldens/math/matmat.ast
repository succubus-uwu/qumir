(block
  (fun main ()
    (block
      (var n i64)
      (var i i64)
      (var j i64)
      (var k i64)
      (= n 16)
      (var A <array f64 2> [0 (- n 1)] [0 (- n 1)])
      (var B <array f64 2> [0 (- n 1)] [0 (- n 1)])
      (var C <array f64 2> [0 (- n 1)] [0 (- n 1)])
      (var sum f64)
      (var err f64)
      (var absv f64)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (if (<= j i) (block (= A [i j] 1)) (block (= A [i j] 0)))
              (if (>= j i) (block (= B [i j] 1)) (block (= B [i j] 0)))))))
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (= sum 0)
              (for k 0 (- n 1) 1 (block (= sum (+ sum (* (index A [i k]) (index B [k j]))))))
              (= C [i j] sum)))))
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (for j
            0
            (- n 1)
            1
            (block
              (if
                (< i j)
                (block
                  (= err (- (index C [i j]) (+ (cast i f64) 1))))
                (block
                  (= err (- (index C [i j]) (+ (cast j f64) 1)))))
              (= absv err)
              (if (< absv 0) (block (= absv (- absv))))
              (= res_l2_sq (+ res_l2_sq (* err err)))
              (if (> absv res_inf) (block (= res_inf absv)))))))
      (= res_l2 (call sqrt res_l2_sq))
      (block
        (call output_string "matmat: ||e||_2^2 = ")
        (call output_double res_l2_sq 0 -1)
        (call output_string "\n"))
      (block
        (call output_string "matmat: ||e||_2    = ")
        (call output_double res_l2 0 -1)
        (call output_string "\n"))
      (block
        (call output_string "matmat: ||e||_inf  = ")
        (call output_double res_inf 0 -1)
        (call output_string "\n"))
      (cleanup-exit (return) (destroy C) (destroy B) (destroy A)))))