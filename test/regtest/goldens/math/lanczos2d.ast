        (= $$v1_lbound0 1)
        (= $$v1_dimsize0 (+ (- NI 1) 1))
        (= $$v1_mulacc0 (* (* 1 $$v1_dimsize1) $$v1_dimsize0))
        (var v1 <array f64 2>))
      (seq
        (var $$w_lbound1 i64)
        (var $$w_dimsize1 i64)
        (var $$w_mulacc1 i64)
        (= $$w_lbound1 1)
        (= $$w_dimsize1 (+ (- NJ 1) 1))
        (= $$w_mulacc1 (* 1 $$w_dimsize1))
        (var $$w_lbound0 i64)
        (var $$w_dimsize0 i64)
        (var $$w_mulacc0 i64)
        (= $$w_lbound0 1)
        (= $$w_dimsize0 (+ (- NI 1) 1))
        (= $$w_mulacc0 (* (* 1 $$w_dimsize1) $$w_dimsize0))
        (var w <array f64 2>))
      (seq
        (var $$Q_lbound2 i64)
        (var $$Q_dimsize2 i64)
        (var $$Q_mulacc2 i64)
        (= $$Q_lbound2 1)
        (= $$Q_dimsize2 (+ (- NJ 1) 1))
        (= $$Q_mulacc2 (* 1 $$Q_dimsize2))
        (var $$Q_lbound1 i64)
        (var $$Q_dimsize1 i64)
        (var $$Q_mulacc1 i64)
        (= $$Q_lbound1 1)
        (= $$Q_dimsize1 (+ (- NI 1) 1))
        (= $$Q_mulacc1 (* (* 1 $$Q_dimsize2) $$Q_dimsize1))
        (var $$Q_lbound0 i64)
        (var $$Q_dimsize0 i64)
        (var $$Q_mulacc0 i64)
        (= $$Q_lbound0 0)
        (= $$Q_dimsize0 (+ (- (- m 1) 0) 1))
        (= $$Q_mulacc0 (* (* (* 1 $$Q_dimsize2) $$Q_dimsize1) $$Q_dimsize0))
        (var Q <array f64 3>))
      (seq
        (var $$alpha_lbound0 i64)
        (var $$alpha_dimsize0 i64)
        (var $$alpha_mulacc0 i64)
        (= $$alpha_lbound0 0)
        (= $$alpha_dimsize0 (+ (- (- m 1) 0) 1))
        (= $$alpha_mulacc0 (* 1 $$alpha_dimsize0))
        (var alpha <array f64 1>))
      (seq
        (var $$beta_lbound0 i64)
        (var $$beta_dimsize0 i64)
        (var $$beta_mulacc0 i64)
        (= $$beta_lbound0 0)
        (= $$beta_dimsize0 (+ (- (- m 2) 0) 1))
        (= $$beta_mulacc0 (* 1 $$beta_dimsize0))
        (var beta <array f64 1>))
      (var i i64)
      (var j i64)
      (var k i64)
      (var t i64)
      (var r i64)
      (var s f64)
      (var nrm f64)
      (var inv f64)
      (var a f64)
      (var b f64)
      (var lo f64)
      (var hi f64)
      (var mid f64)
      (var cnt f64)
      (for i
        1
        NI
        1
        (block
          (for j
            1
            NJ
            1
            (block
              (= v0
                [i
                  j]
                (+ (+ (* (call sin (* pi (* (cast i f64) h))) (call sin (* pi (* (cast j f64) h))))
                    (* (* 0.5 (call sin (* pi (* (* 2 (cast i f64)) h)))) (call sin (* pi (* (cast j f64) h)))))
                  (* (* 0.5 (call sin (* pi (* (cast i f64) h)))) (call sin (* pi (* (* 2 (cast j f64)) h))))))))))
      (= nrm 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= nrm (+ nrm (* (index [i j] v0) (index [i j] v0))))))))
      (= nrm (call sqrt nrm))
      (= inv (/ 1 nrm))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= v0 [i j] (* (index [i j] v0) inv)) (= Q [0 i j] (index [i j] v0))))))
      (call matvec_A Nx Ny NI NJ h2 v0 w)
      (= alpha [0] (call dot2 NI NJ v0 w))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index [i j] w) (* (index 0 alpha) (index [i j] v0))))))))
      (= s 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index [0 i j] Q) (index [i j] w))))))))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index [i j] w) (* s (index [0 i j] Q))))))))
      (cond (> m 1) (block (= beta [0] (call norm2_2d NI NJ w))))
      (for k
        1
        (- m 1)
        1
        (block
          (cond (== (index (- k 1) beta) 0) (block (= alpha [k] 0) break))
          (= inv (/ 1 (index (- k 1) beta)))
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= v1 [i j] (* (index [i j] w) inv)) (= Q [k i j] (index [i j] v1))))))
          (call matvec_A Nx Ny NI NJ h2 v1 w)
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= w [i j] (- (index [i j] w) (* (index (- k 1) beta) (index [(- k 1) i j] Q))))))))
          (= alpha [k] (call dot2 NI NJ v1 w))
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= w [i j] (- (index [i j] w) (* (index k alpha) (index [i j] v1))))))))
          (for r
            0
            k
            1
            (block
              (= s 0)
              (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index [r i j] Q) (index [i j] w))))))))
              (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index [i j] w) (* s (index [r i j] Q))))))))))
          (cond (< k (- m 1)) (block (= beta [k] (call norm2_2d NI NJ w))))
          (for i 1 NI 1 (block (for j 1 NJ 1 (block (= v0 [i j] (index [i j] v1))))))))
      (= a (index 0 alpha))
      (= b (index 0 alpha))
      (= s 0)
      (for k
        0
        (- m 1)
        1
        (block
          (cond (< (index k alpha) a) (block (= a (index k alpha))))
          (cond (> (index k alpha) b) (block (= b (index k alpha))))
          (cond (&& (< k (- m 1)) (> (index k beta) s)) (block (= s (index k beta))))))
      (= lo (- a (* 2 s)))
      (= hi (+ b (* 2 s)))
      (seq
        (var $$evals_lbound0 i64)
        (var $$evals_dimsize0 i64)
        (var $$evals_mulacc0 i64)
        (= $$evals_lbound0 0)
        (= $$evals_dimsize0 (+ (- (- want 1) 0) 1))
        (= $$evals_mulacc0 (* 1 $$evals_dimsize0))
        (var evals <array f64 1>))
      (var eps f64)
      (= eps 1e-10)
      (for t
        1
        want
        1
        (block
          (= a lo)
          (= b hi)
          (for j
            0
            80
            1
            (block
              (= mid (* 0.5 (+ a b)))
              (= cnt (cast (call sturm_count m alpha beta mid) f64))
              (cond (>= cnt (cast t f64)) (block (= b mid)) (block (= a mid)))))
          (= evals [(- t 1)] (* 0.5 (+ a b)))))
      (seq
        (call output_string "Lanczos2D: N=")
        (call output_int64 Nx 0)
        (call output_symbol (cast 120 char))
        (call output_int64 Ny 0)
        (call output_string ", m=")
        (call output_int64 m 0)
        (call output_string ", want=")
        (call output_int64 want 0)
        (call output_symbol (cast 10 char)))
      (for t
        0
        (- want 1)
        1
        (block
          (seq
            (call output_string "  λ[")
            (call output_int64 (+ t 1) 0)
            (call output_string "] ≈ ")
            (call output_double (index t evals) 8 8)
            (call output_symbol (cast 10 char)))))
      (var lam11 f64)
      (var lam12 f64)
      (var lam21 f64)
      (var lam13 f64)
      (var lam22 f64)
      (= lam11
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam12
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam21
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam13
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 3) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam22
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Ny 1) f64)))) 2))))
      (seq
        (call output_string "Analytic few (unordered): ")
        (call output_double lam11 8 8)
        (call output_string ", ")
        (call output_double lam12 8 8)
        (call output_string ", ")
        (call output_double lam21 8 8)
        (call output_string ", ")
        (call output_double lam13 8 8)
        (call output_string ", ")
        (call output_double lam22 8 8)
        (call output_symbol (cast 10 char)))))
  (fun dot f64 ((var N i64)
      (var x <array f64 1>)
      (var y <array f64 1>)) ()
    (block
      (var $$x_lbound0 i64)
      (var $$x_dimsize0 i64)
      (var $$x_mulacc0 i64)
      (= $$x_lbound0 0)
      (= $$x_dimsize0 (+ (- (- N 1) 0) 1))
      (= $$x_mulacc0 (* 1 $$x_dimsize0))
      (var $$y_lbound0 i64)
      (var $$y_dimsize0 i64)
      (var $$y_mulacc0 i64)
      (= $$y_lbound0 0)
      (= $$y_dimsize0 (+ (- (- N 1) 0) 1))
      (= $$y_mulacc0 (* 1 $$y_dimsize0))
      (var $$return f64)
      (var s f64)
      (var i i64)
      (= s 0)
      (for i 0 (- N 1) 1 (block (= s (+ s (* (index i x) (index i y))))))
      (= $$return s)))
  (fun norm2 f64 ((var N i64)
