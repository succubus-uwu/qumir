      (= $$return s)))
  (fun matvec_A void ((var Nx i64)
      (var Ny i64)
      (var NI i64)
      (var NJ i64)
      (var h2 f64)
      (var x <array f64 2>)
      (var y <array f64 2>)) ()
    (block
      (var $$x_lbound1 i64)
      (var $$x_dimsize1 i64)
      (var $$x_mulacc1 i64)
      (= $$x_lbound1 1)
      (= $$x_dimsize1 (+ (- NJ 1) 1))
      (= $$x_mulacc1 (* 1 $$x_dimsize1))
      (var $$x_lbound0 i64)
      (var $$x_dimsize0 i64)
      (var $$x_mulacc0 i64)
      (= $$x_lbound0 1)
      (= $$x_dimsize0 (+ (- NI 1) 1))
      (= $$x_mulacc0 (* (* 1 $$x_dimsize1) $$x_dimsize0))
      (var $$y_lbound1 i64)
      (var $$y_dimsize1 i64)
      (var $$y_mulacc1 i64)
      (= $$y_lbound1 1)
      (= $$y_dimsize1 (+ (- NJ 1) 1))
      (= $$y_mulacc1 (* 1 $$y_dimsize1))
      (var $$y_lbound0 i64)
      (var $$y_dimsize0 i64)
      (var $$y_mulacc0 i64)
      (= $$y_lbound0 1)
      (= $$y_dimsize0 (+ (- NI 1) 1))
      (= $$y_mulacc0 (* (* 1 $$y_dimsize1) $$y_dimsize0))
      (var i i64)
      (var j i64)
      (var c f64)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= y [i j] 0)))))
      (for i
        1
        NI
        1
        (block
          (for j
            1
            NJ
            1
            (block
              (= c (* 4 (index [i j] x)))
              (cond (> i 1) (block (= c (- c (index [(- i 1) j] x)))))
              (cond (< i NI) (block (= c (- c (index [(+ i 1) j] x)))))
              (cond (> j 1) (block (= c (- c (index [i (- j 1)] x)))))
              (cond (< j NJ) (block (= c (- c (index [i (+ j 1)] x)))))
              (= y [i j] (/ c h2))))))))
  (fun sturm_count i64 ((var m i64)
      (var alpha <array f64 1>)
      (var beta <array f64 1>)
      (var lam f64)) ()
    (block
      (var $$alpha_lbound0 i64)
      (var $$alpha_dimsize0 i64)
      (var $$alpha_mulacc0 i64)
      (= $$alpha_lbound0 0)
      (= $$alpha_dimsize0 (+ (- (- m 1) 0) 1))
      (= $$alpha_mulacc0 (* 1 $$alpha_dimsize0))
      (var $$beta_lbound0 i64)
      (var $$beta_dimsize0 i64)
      (var $$beta_mulacc0 i64)
      (= $$beta_lbound0 0)
      (= $$beta_dimsize0 (+ (- (- m 2) 0) 1))
      (= $$beta_mulacc0 (* 1 $$beta_dimsize0))
      (var $$return i64)
      (var i i64)
      (var count i64)
      (var d f64)
      (var prev f64)
      (= count 0)
      (= d (- (index 0 alpha) lam))
      (cond (< d 0) (block (= count (+ count 1))))
      (for i
        1
        (- m 1)
        1
        (block
          (cond
            (< (let (($$value d)) (if (< $$value 0) (- $$value) $$value)) 1e-14)
            (block
              (cond (>= d 0) (block (= d 1e-14)) (block (= d (- 1e-14))))))
          (= d (- (- (index i alpha) lam) (/ (* (index (- i 1) beta) (index (- i 1) beta)) d)))
          (cond (< d 0) (block (= count (+ count 1))))))
      (= $$return count))))