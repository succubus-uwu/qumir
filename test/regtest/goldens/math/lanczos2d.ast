        (var $$v0_dimsize0 i64)
        (var $$v0_mulacc0 i64)
        (= $$v0_lbound0 1)
        (= $$v0_dimsize0 (+ (- NI 1) 1))
        (= $$v0_mulacc0 (* (* 1 $$v0_dimsize1) $$v0_dimsize0))
        (var v0 <array f64 2>))
      (seq
