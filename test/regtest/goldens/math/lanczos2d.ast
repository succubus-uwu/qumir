(block
  (fun lanczos2d void () ()
    (block
      (var Nx i64)
      (var Ny i64)
      (= Nx 8)
      (= Ny 8)
      (var h f64)
      (var h2 f64)
      (var pi f64)
      (= pi 3.14159)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (= h2 (* h h))
      (var NI i64)
      (var NJ i64)
      (var N i64)
      (= NI (- Nx 2))
      (= NJ (- Ny 2))
      (= N (* NI NJ))
      (var m i64)
      (var want i64)
      (= m 100)
      (= want 5)
      (seq
        (var $$v0_lbound1 i64)
        (var $$v0_dimsize1 i64)
        (var $$v0_mulacc1 i64)
        (= $$v0_lbound1 1)
        (= $$v0_dimsize1 (+ (- NJ 1) 1))
        (= $$v0_mulacc1 (* 1 $$v0_dimsize1))
