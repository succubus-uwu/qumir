      (= s 0)
      (for i 0 (- N 1) 1 (block (= s (+ s (* (index i x) (index i x))))))
      (= s (call sqrt s))
      (= $$return s)))
  (fun dot2 f64 ((var NI i64)
      (var NJ i64)
      (var x <array f64 2>)
      (var y <array f64 2>)) ()
    (block
      (var $$x_lbound1 i64)
      (var $$x_dimsize1 i64)
      (var $$x_mulacc1 i64)
      (= $$x_lbound1 1)
      (= $$x_dimsize1 (+ (- NJ 1) 1))
      (= $$x_mulacc1 (* 1 $$x_dimsize1))
      (var $$x_lbound0 i64)
      (var $$x_dimsize0 i64)
      (var $$x_mulacc0 i64)
      (= $$x_lbound0 1)
      (= $$x_dimsize0 (+ (- NI 1) 1))
      (= $$x_mulacc0 (* (* 1 $$x_dimsize1) $$x_dimsize0))
