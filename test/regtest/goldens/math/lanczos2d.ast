      (= s 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index [i j] x) (index [i j] y))))))))
      (= $$return s)))
  (fun norm2_2d f64 ((var NI i64)
      (var NJ i64)
      (var x <array f64 2>)) ()
    (block
      (var $$x_lbound1 i64)
      (var $$x_dimsize1 i64)
      (var $$x_mulacc1 i64)
      (= $$x_lbound1 1)
      (= $$x_dimsize1 (+ (- NJ 1) 1))
      (= $$x_mulacc1 (* 1 $$x_dimsize1))
      (var $$x_lbound0 i64)
      (var $$x_dimsize0 i64)
      (var $$x_mulacc0 i64)
