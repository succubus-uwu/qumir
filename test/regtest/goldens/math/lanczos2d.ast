(block
  (fun lanczos2d ()
    (block
      (var Nx i64)
      (var Ny i64)
      (= Nx 8)
      (= Ny 8)
      (var h f64)
      (var h2 f64)
      (var pi f64)
      (= pi 3.1415926866674426)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (= h2 (* h h))
      (var NI i64)
      (var NJ i64)
      (var N i64)
      (= NI (- Nx 2))
      (= NJ (- Ny 2))
      (= N (* NI NJ))
      (var m i64)
      (var want i64)
      (= m 100)
      (= want 5)
      (var v0 <array f64 2> [1 NI] [1 NJ])
      (var v1 <array f64 2> [1 NI] [1 NJ])
      (var w <array f64 2> [1 NI] [1 NJ])
      (var Q <array f64 3> [0 (- m 1)] [1 NI] [1 NJ])
      (var alpha <array f64 1> [0 (- m 1)])
      (var beta <array f64 1> [0 (- m 2)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var t i64)
      (var r i64)
      (var s f64)
      (var nrm f64)
      (var inv f64)
      (var a f64)
      (var b f64)
      (var lo f64)
      (var hi f64)
      (var mid f64)
      (var cnt f64)
      (for i
        1
        NI
        1
        (block
          (for j
            1
            NJ
            1
            (block
              (= v0
                [i
                  j]
                (+ (+ (* (call sin (* pi (* (cast i f64) h))) (call sin (* pi (* (cast j f64) h))))
                    (* (* 0.5 (call sin (* pi (* (* 2 (cast i f64)) h)))) (call sin (* pi (* (cast j f64) h)))))
                  (* (* 0.5 (call sin (* pi (* (cast i f64) h)))) (call sin (* pi (* (* 2 (cast j f64)) h))))))))))
      (= nrm 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= nrm (+ nrm (* (index v0 [i j]) (index v0 [i j]))))))))
      (= nrm (call sqrt nrm))
      (= inv (/ 1 nrm))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= v0 [i j] (* (index v0 [i j]) inv)) (= Q [0 i j] (index v0 [i j]))))))
      (call matvec_A Nx Ny NI NJ h2 v0 w)
      (= alpha [0] (call dot2 NI NJ v0 w))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index w [i j]) (* (index alpha 0) (index v0 [i j]))))))))
      (= s 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index Q [0 i j]) (index w [i j]))))))))
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index w [i j]) (* s (index Q [0 i j]))))))))
      (if (> m 1) (block (= beta [0] (call norm2_2d NI NJ w))))
      (for k
        1
        (- m 1)
        1
        (block
          (if (== (index beta (- k 1)) 0) (block (= alpha [k] 0) (cleanup-exit (break))))
          (= inv (/ 1 (index beta (- k 1))))
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= v1 [i j] (* (index w [i j]) inv)) (= Q [k i j] (index v1 [i j]))))))
          (call matvec_A Nx Ny NI NJ h2 v1 w)
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= w [i j] (- (index w [i j]) (* (index beta (- k 1)) (index Q [(- k 1) i j]))))))))
          (= alpha [k] (call dot2 NI NJ v1 w))
          (for i
            1
            NI
            1
            (block
              (for j 1 NJ 1 (block (= w [i j] (- (index w [i j]) (* (index alpha k) (index v1 [i j]))))))))
          (for r
            0
            k
            1
            (block
              (= s 0)
              (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index Q [r i j]) (index w [i j]))))))))
              (for i 1 NI 1 (block (for j 1 NJ 1 (block (= w [i j] (- (index w [i j]) (* s (index Q [r i j]))))))))))
          (if (< k (- m 1)) (block (= beta [k] (call norm2_2d NI NJ w))))
          (for i 1 NI 1 (block (for j 1 NJ 1 (block (= v0 [i j] (index v1 [i j]))))))))
      (= a (index alpha 0))
      (= b (index alpha 0))
      (= s 0)
      (for k
        0
        (- m 1)
        1
        (block
          (if (< (index alpha k) a) (block (= a (index alpha k))))
          (if (> (index alpha k) b) (block (= b (index alpha k))))
          (if (&& (< k (- m 1)) (> (index beta k) s)) (block (= s (index beta k))))))
      (= lo (- a (* 2 s)))
      (= hi (+ b (* 2 s)))
      (var evals <array f64 1> [0 (- want 1)])
      (var eps f64)
      (= eps 1e-10)
      (for t
        1
        want
        1
        (block
          (= a lo)
          (= b hi)
          (for j
            0
            80
            1
            (block
              (= mid (* 0.5 (+ a b)))
              (= cnt (cast (call sturm_count m alpha beta mid) f64))
              (if (>= cnt (cast t f64)) (block (= b mid)) (block (= a mid)))))
          (= evals [(- t 1)] (* 0.5 (+ a b)))))
      (block
        (call output_string "Lanczos2D: N=")
        (call output_int64 Nx 0)
        (call output_symbol (cast 120 char))
        (call output_int64 Ny 0)
        (call output_string ", m=")
        (call output_int64 m 0)
        (call output_string ", want=")
        (call output_int64 want 0)
        (call output_symbol (cast 10 char)))
      (for t
        0
        (- want 1)
        1
        (block
          (block
            (call output_string "  λ[")
            (call output_int64 (+ t 1) 0)
            (call output_string "] ≈ ")
            (call output_double (index evals t) 8 8)
            (call output_symbol (cast 10 char)))))
      (var lam11 f64)
      (var lam12 f64)
      (var lam21 f64)
      (var lam13 f64)
      (var lam22 f64)
      (= lam11
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam12
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam21
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam13
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 1) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 3) (* 2 (cast (- Ny 1) f64)))) 2))))
      (= lam22
        (* (/ 4 h2)
          (+ (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Nx 1) f64)))) 2)
            (call fpow (call sin (/ (* pi 2) (* 2 (cast (- Ny 1) f64)))) 2))))
      (block
        (call output_string "Analytic few (unordered): ")
        (call output_double lam11 8 8)
        (call output_string ", ")
        (call output_double lam12 8 8)
        (call output_string ", ")
        (call output_double lam21 8 8)
        (call output_string ", ")
        (call output_double lam13 8 8)
        (call output_string ", ")
        (call output_double lam22 8 8)
        (call output_symbol (cast 10 char)))
      (cleanup-exit
        (return)
        (destroy evals)
        (destroy beta)
        (destroy alpha)
        (destroy Q)
        (destroy w)
        (destroy v1)
        (destroy v0))))
  (fun dot ((var N i64)
      (var x <array f64 1> [0 (- N 1)])
      (var y <array f64 1> [0 (- N 1)])) -> f64
    (block
      (var знач f64)
      (var s f64)
      (var i i64)
      (= s 0)
      (for i 0 (- N 1) 1 (block (= s (+ s (* (index x i) (index y i))))))
      (= знач s)
      (cleanup-exit (return знач))))
  (fun norm2 ((var N i64)
      (var x <array f64 1> [0 (- N 1)])) -> f64
    (block
      (var знач f64)
      (var s f64)
      (var i i64)
      (= s 0)
      (for i 0 (- N 1) 1 (block (= s (+ s (* (index x i) (index x i))))))
      (= s (call sqrt s))
      (= знач s)
      (cleanup-exit (return знач))))
  (fun dot2 ((var NI i64)
      (var NJ i64)
      (var x <array f64 2> [1 NI] [1 NJ])
      (var y <array f64 2> [1 NI] [1 NJ])) -> f64
    (block
      (var знач f64)
      (var s f64)
      (var i i64)
      (var j i64)
      (= s 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index x [i j]) (index y [i j]))))))))
      (= знач s)
      (cleanup-exit (return знач))))
  (fun norm2_2d ((var NI i64)
      (var NJ i64)
      (var x <array f64 2> [1 NI] [1 NJ])) -> f64
    (block
      (var знач f64)
      (var s f64)
      (var i i64)
      (var j i64)
      (= s 0)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= s (+ s (* (index x [i j]) (index x [i j]))))))))
      (= s (call sqrt s))
      (= знач s)
      (cleanup-exit (return знач))))
  (fun matvec_A ((var Nx i64)
      (var Ny i64)
      (var NI i64)
      (var NJ i64)
      (var h2 f64)
      (var x <array f64 2> [1 NI] [1 NJ])
      (var y <array f64 2> [1 NI] [1 NJ]))
    (block
      (var i i64)
      (var j i64)
      (var c f64)
      (for i 1 NI 1 (block (for j 1 NJ 1 (block (= y [i j] 0)))))
      (for i
        1
        NI
        1
        (block
          (for j
            1
            NJ
            1
            (block
              (= c (* 4 (index x [i j])))
              (if (> i 1) (block (= c (- c (index x [(- i 1) j])))))
              (if (< i NI) (block (= c (- c (index x [(+ i 1) j])))))
              (if (> j 1) (block (= c (- c (index x [i (- j 1)])))))
              (if (< j NJ) (block (= c (- c (index x [i (+ j 1)])))))
              (= y [i j] (/ c h2))))))
      (cleanup-exit (return))))
  (fun sturm_count ((var m i64)
      (var alpha <array f64 1> [0 (- m 1)])
      (var beta <array f64 1> [0 (- m 2)])
      (var lam f64)) -> i64
    (block
      (var знач i64)
      (var i i64)
      (var count i64)
      (var d f64)
      (var prev f64)
      (= count 0)
      (= d (- (index alpha 0) lam))
      (if (< d 0) (block (= count (+ count 1))))
      (for i
        1
        (- m 1)
        1
        (block
          (if
            (< (block (var $$value = d) (if (< $$value 0) (- $$value) $$value)) 1e-14)
            (block
              (if (>= d 0) (block (= d 1e-14)) (block (= d (- 1e-14))))))
          (= d (- (- (index alpha i) lam) (/ (* (index beta (- i 1)) (index beta (- i 1))) d)))
          (if (< d 0) (block (= count (+ count 1))))))
      (= знач count)
      (cleanup-exit (return знач)))))