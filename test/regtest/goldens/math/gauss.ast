(block
  (fun main ()
    (block
      (var n i64)
      (var Eps f64)
      (= n 64)
      (= Eps -1.3747972778925911e-09)
      (var A <array f64 2> [0 (- n 1)] [0 (- n 1)])
      (var B <array f64 1> [0 (- n 1)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var _imax i64)
      (var t i64)
      (var p f64)
      (var tmp f64)
      (var bestSq f64)
      (var curSq f64)
      (var sum f64)
      (var rowmax f64)
      (var scale f64)
      (for i 0 (- n 1) 1 (block (for j 0 (- n 1) 1 (block (= A [i j] (/ 1 (+ (cast (+ i j) f64) 1))))) (= B [i] 1)))
      (for k
        0
        (- n 1)
        1
        (block
          (= _imax k)
          (= bestSq (* (index A [k k]) (index A [k k])))
          (for i
            (+ k 1)
            (- n 1)
            1
            (block
              (= curSq (* (index A [i k]) (index A [i k])))
              (if (> curSq bestSq) (block (= bestSq curSq) (= _imax i)))))
          (if
            (!= _imax k)
            (block
              (for j k (- n 1) 1 (block (= tmp (index A [k j])) (= A [k j] (index A [_imax j])) (= A [_imax j] tmp)))
              (= tmp (index B k))
              (= B [k] (index B _imax))
              (= B [_imax] tmp)))
          (= p (index A [k k]))
          (= rowmax 0)
          (for j
            k
            (- n 1)
            1
            (block
              (= sum (index A [k j]))
              (if (< sum 0) (block (= sum (- sum))))
              (if (> sum rowmax) (block (= rowmax sum)))))
          (= scale (* Eps rowmax))
          (= sum p)
          (if (< sum 0) (block (= sum (- sum))))
          (if (<= sum scale) (block (cleanup-exit (break))))
          (for j k (- n 1) 1 (block (= A [k j] (/ (index A [k j]) p))))
          (= B [k] (/ (index B k) p))
          (for i
            (+ k 1)
            (- n 1)
            1
            (block
              (= tmp (index A [i k]))
              (if
                (!= tmp 0)
                (block
                  (for j k (- n 1) 1 (block (= A [i j] (- (index A [i j]) (* (index A [k j]) tmp)))))
                  (= B [i] (- (index B i) (* (index B k) tmp)))))))))
      (for t
        0
        (- n 1)
        1
        (block
          (= i (- (- n 1) t))
          (= sum (index B i))
          (for j (+ i 1) (- n 1) 1 (block (= sum (- sum (* (index A [i j]) (index B j))))))
          (if (!= (index A [i i]) 0) (block (= B [i] (/ sum (index A [i i])))) (block (= B [i] 0)))))
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (var r f64)
      (var absv f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (/ 1 (+ (cast (+ i j) f64) 1)) (index B j))))))
          (= r (- sum 1))
          (= absv r)
          (if (< absv 0) (block (= absv (- absv))))
          (= res_l2_sq (+ res_l2_sq (* r r)))
          (if (> absv res_inf) (block (= res_inf absv)))))
      (= res_l2 (call sqrt res_l2_sq))
      (block
        (call output_string "||r||_2^2 = ")
        (call output_double res_l2_sq 8 8)
        (call output_string "\n"))
      (block
        (call output_string "||r||_2    = ")
        (call output_double res_l2 8 8)
        (call output_string "\n"))
      (block
        (call output_string "||r||_inf  = ")
        (call output_double res_inf 8 8)
        (call output_string "\n"))
      (cleanup-exit (return) (destroy B) (destroy A)))))