(block
  (fun main ()
    (block
      (var n i64)
      (var m i64)
      (var maxRestart i64)
      (var tol f64)
      (= n 16)
      (= m 20)
      (= maxRestart 20)
      (= tol 7.0918695992859933e-10)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array f64 1> [0 (- n 1)])
      (var w <array f64 1> [0 (- n 1)])
      (var V <array f64 2> [0 m] [0 (- n 1)])
      (var H <array f64 2> [0 m] [0 (- m 1)])
      (var cs <array f64 1> [0 (- m 1)])
      (var sn <array f64 1> [0 (- m 1)])
      (var g <array f64 1> [0 m])
      (var y <array f64 1> [0 (- m 1)])
      (var tmpv <array f64 1> [0 (- n 1)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var it i64)
      (var jArn i64)
      (var sum f64)
      (var absv f64)
      (var beta f64)
      (var rnorm f64)
      (var tmp f64)
      (var denom f64)
      (var hi f64)
      (var hip1 f64)
      (var rho f64)
      (for i 0 (- n 1) 1 (block (= b [i] 1) (= x [i] 0)))
      (= it 0)
      (while
        (< it maxRestart)
        (block
          (call compute_residual n x b r w)
          (= beta (call norm2 n r))
          (= rnorm beta)
          (if (<= rnorm tol) (block break))
          (for i 0 (- n 1) 1 (block (= V [0 i] (/ (index r i) beta))))
          (= g [0] beta)
          (for j 1 m 1 (block (= g [j] 0)))
          (= jArn (- m 1))
          (for j
            0
            (- m 1)
            1
            (block
              (= jArn j)
              (for i 0 (- n 1) 1 (block (= w [i] 0)))
              (for k 0 (- n 1) 1 (block (= tmpv [k] (index V [j k]))))
              (call matvec n tmpv w)
              (for i
                0
                j
                1
                (block
                  (for k 0 (- n 1) 1 (block (= tmpv [k] (index V [i k]))))
                  (= hi (call dot n w tmpv))
                  (= H [i j] hi)
                  (for k 0 (- n 1) 1 (block (= w [k] (- (index w k) (* hi (index V [i k]))))))))
              (= hip1 (call norm2 n w))
              (= H [(+ j 1) j] hip1)
              (if
                (!= hip1 0)
                (block
                  (for k 0 (- n 1) 1 (block (= V [(+ j 1) k] (/ (index w k) hip1)))))
                (block
                  (for k 0 (- n 1) 1 (block (= V [(+ j 1) k] 0)))))
              (for i
                0
                (- j 1)
                1
                (block
                  (= tmp (+ (* (index cs i) (index H [i j])) (* (index sn i) (index H [(+ i 1) j]))))
                  (= H [(+ i 1) j] (+ (* (- (index sn i)) (index H [i j])) (* (index cs i) (index H [(+ i 1) j]))))
                  (= H [i j] tmp)))
              (= denom
                (call sqrt (+ (* (index H [j j]) (index H [j j])) (* (index H [(+ j 1) j]) (index H [(+ j 1) j])))))
              (if
                (!= denom 0)
                (block
                  (= cs [j] (/ (index H [j j]) denom))
                  (= sn [j] (/ (index H [(+ j 1) j]) denom)))
                (block
                  (= cs [j] 1)
                  (= sn [j] 0)))
              (= H [j j] (+ (* (index cs j) (index H [j j])) (* (index sn j) (index H [(+ j 1) j]))))
              (= H [(+ j 1) j] 0)
              (= tmp (* (index cs j) (index g j)))
              (= g [(+ j 1)] (* (- (index sn j)) (index g j)))
              (= g [j] tmp)
              (= rnorm (index g (+ j 1)))
              (if (< rnorm 0) (block (= rnorm (- rnorm))))
              (if (<= rnorm tol) (block (= jArn j) break))))
          (for i 0 jArn 1 (block (= y [i] 0)))
          (for i
            jArn
            0
            (- 1)
            (block
              (= sum (index g i))
              (for k (+ i 1) jArn 1 (block (= sum (- sum (* (index H [i k]) (index y k))))))
              (if (!= (index H [i i]) 0) (block (= y [i] (/ sum (index H [i i])))) (block (= y [i] 0)))))
          (for k
            0
            (- n 1)
            1
            (block
              (= sum 0)
              (for i 0 jArn 1 (block (= sum (+ sum (* (index V [i k]) (index y i))))))
              (= x [k] (+ (index x k) sum))))
          (call compute_residual n x b r w)
          (= rnorm (call norm2 n r))
          (if (<= rnorm tol) (block break))
          (= it (+ it 1))))
      (call compute_residual n x b r w)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (var vabs f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= vabs (index r i))
          (if (< vabs 0) (block (= vabs (- vabs))))
          (= res_l2_sq (+ res_l2_sq (* (index r i) (index r i))))
          (if (> vabs res_inf) (block (= res_inf vabs)))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "gmres: n=")
        (call output_int64 n 0)
        (call output_string ", m=")
        (call output_int64 m 0)
        (call output_string "\n"))
      (seq
        (call output_string "restarts=")
        (call output_int64 it 0)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_2= ")
        (call output_double res_l2 8 8)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_inf= ")
        (call output_double res_inf 8 8)
        (call output_string "\n"))))
  (fun matvec ((var n i64)
      (var v <array f64 1> [0 (- n 1)])
      (var w <array <f64 (mutable)> 1> [0 (- n 1)]))
    (block
      (var i i64)
      (var j i64)
      (var sum f64)
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (/ 1 (+ (cast (+ i j) f64) 1)) (index v j))))))
          (= w [i] sum)))))
  (fun norm2 ((var n i64)
      (var v <array f64 1> [0 (- n 1)])) -> f64
    (block
      (var знач f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index v i) (index v i))))))
      (= знач (call sqrt sum))))
  (fun dot ((var n i64)
      (var a <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])) -> f64
    (block
      (var знач f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index a i) (index b i))))))
      (= знач sum)))
  (fun compute_residual ((var n i64)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array <f64 (mutable)> 1> [0 (- n 1)])
      (var w <array f64 1> [0 (- n 1)]))
    (block
      (var i i64)
      (call matvec n x w)
      (for i 0 (- n 1) 1 (block (= r [i] (- (index b i) (index w i))))))))