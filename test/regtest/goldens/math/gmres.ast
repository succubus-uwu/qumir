        (= $$tmpv_lbound0 0)
        (= $$tmpv_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$tmpv_mulacc0 (* 1 $$tmpv_dimsize0))
        (var tmpv <array f64 1>))
      (var i i64)
