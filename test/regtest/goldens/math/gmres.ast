(block
  (fun main void () ()
    (block
      (var n i64)
      (var m i64)
      (var maxRestart i64)
      (var tol f64)
      (= n 16)
      (= m 20)
      (= maxRestart 20)
      (= tol 7.0918695992859933e-10)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array f64 1> [0 (- n 1)])
      (var w <array f64 1> [0 (- n 1)])
      (var V <array f64 2> [0 m] [0 (- n 1)])
      (var H <array f64 2> [0 m] [0 (- m 1)])
      (var cs <array f64 1> [0 (- m 1)])
      (var sn <array f64 1> [0 (- m 1)])
      (var g <array f64 1> [0 m])
      (var y <array f64 1> [0 (- m 1)])
      (var tmpv <array f64 1> [0 (- n 1)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var it i64)
      (var jArn i64)
      (var sum f64)
      (var absv f64)
      (var beta f64)
      (var rnorm f64)
      (var tmp f64)
      (var denom f64)
      (var hi f64)
      (var hip1 f64)
      (var rho f64)
      (for i 0 (- n 1) 1 (block (= b [i] 1) (= x [i] 0)))
      (= it 0)
      (while
        (< it maxRestart)
        (block
          (call compute_residual n x b r w)
          (= beta (call norm2 n r))
          (= rnorm beta)
          (cond (<= rnorm tol) (block break))
          (for i 0 (- n 1) 1 (block (= V [0 i] (/ (index i r) beta))))
          (= g [0] beta)
          (for j 1 m 1 (block (= g [j] 0)))
          (= jArn (- m 1))
          (for j
            0
            (- m 1)
            1
            (block
              (= jArn j)
              (for i 0 (- n 1) 1 (block (= w [i] 0)))
              (for k 0 (- n 1) 1 (block (= tmpv [k] (index [j k] V))))
              (call matvec n tmpv w)
              (for i
                0
                j
                1
                (block
                  (for k 0 (- n 1) 1 (block (= tmpv [k] (index [i k] V))))
                  (= hi (call dot n w tmpv))
                  (= H [i j] hi)
                  (for k 0 (- n 1) 1 (block (= w [k] (- (index k w) (* hi (index [i k] V))))))))
              (= hip1 (call norm2 n w))
              (= H [(+ j 1) j] hip1)
              (cond
                (!= hip1 0)
                (block
                  (for k 0 (- n 1) 1 (block (= V [(+ j 1) k] (/ (index k w) hip1)))))
                (block
                  (for k 0 (- n 1) 1 (block (= V [(+ j 1) k] 0)))))
              (for i
                0
                (- j 1)
                1
                (block
                  (= tmp (+ (* (index i cs) (index [i j] H)) (* (index i sn) (index [(+ i 1) j] H))))
                  (= H [(+ i 1) j] (+ (* (- (index i sn)) (index [i j] H)) (* (index i cs) (index [(+ i 1) j] H))))
                  (= H [i j] tmp)))
              (= denom
                (call sqrt (+ (* (index [j j] H) (index [j j] H)) (* (index [(+ j 1) j] H) (index [(+ j 1) j] H)))))
              (cond
                (!= denom 0)
                (block
                  (= cs [j] (/ (index [j j] H) denom))
                  (= sn [j] (/ (index [(+ j 1) j] H) denom)))
                (block
                  (= cs [j] 1)
                  (= sn [j] 0)))
              (= H [j j] (+ (* (index j cs) (index [j j] H)) (* (index j sn) (index [(+ j 1) j] H))))
              (= H [(+ j 1) j] 0)
              (= tmp (* (index j cs) (index j g)))
              (= g [(+ j 1)] (* (- (index j sn)) (index j g)))
              (= g [j] tmp)
              (= rnorm (index (+ j 1) g))
              (cond (< rnorm 0) (block (= rnorm (- rnorm))))
              (cond (<= rnorm tol) (block (= jArn j) break))))
          (for i 0 jArn 1 (block (= y [i] 0)))
          (for i
            jArn
            0
            (- 1)
            (block
              (= sum (index i g))
              (for k (+ i 1) jArn 1 (block (= sum (- sum (* (index [i k] H) (index k y))))))
              (cond (!= (index [i i] H) 0) (block (= y [i] (/ sum (index [i i] H)))) (block (= y [i] 0)))))
          (for k
            0
            (- n 1)
            1
            (block
              (= sum 0)
              (for i 0 jArn 1 (block (= sum (+ sum (* (index [i k] V) (index i y))))))
              (= x [k] (+ (index k x) sum))))
          (call compute_residual n x b r w)
          (= rnorm (call norm2 n r))
          (cond (<= rnorm tol) (block break))
          (= it (+ it 1))))
      (call compute_residual n x b r w)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (var vabs f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= vabs (index i r))
          (cond (< vabs 0) (block (= vabs (- vabs))))
          (= res_l2_sq (+ res_l2_sq (* (index i r) (index i r))))
          (cond (> vabs res_inf) (block (= res_inf vabs)))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "gmres: n=")
        (call output_int64 n 0)
        (call output_string ", m=")
        (call output_int64 m 0)
        (call output_string "\n"))
      (seq
        (call output_string "restarts=")
        (call output_int64 it 0)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_2= ")
        (call output_double res_l2 8 8)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_inf= ")
        (call output_double res_inf 8 8)
        (call output_string "\n"))))
  (fun matvec void ((var n i64)
      (var v <array f64 1> [0 (- n 1)])
      (var w <array <f64 (mutable)> 1> [0 (- n 1)])) ()
    (block
      (var i i64)
      (var j i64)
      (var sum f64)
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (/ 1 (+ (cast (+ i j) f64) 1)) (index j v))))))
          (= w [i] sum)))))
  (fun norm2 f64 ((var n i64)
      (var v <array f64 1> [0 (- n 1)])) ()
    (block
      (var $$return f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index i v) (index i v))))))
      (= $$return (call sqrt sum))))
  (fun dot f64 ((var n i64)
      (var a <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])) ()
    (block
      (var $$return f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index i a) (index i b))))))
      (= $$return sum)))
  (fun compute_residual void ((var n i64)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array <f64 (mutable)> 1> [0 (- n 1)])
      (var w <array f64 1> [0 (- n 1)])) ()
    (block
      (var i i64)
      (call matvec n x w)
      (for i 0 (- n 1) 1 (block (= r [i] (- (index i b) (index i w))))))))