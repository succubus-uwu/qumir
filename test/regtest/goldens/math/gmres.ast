      (var tmp f64)
      (var denom f64)
      (var hi f64)
      (var hip1 f64)
      (var rho f64)
      (for i 0 (- n 1) 1 (block (= b [i] 1) (= x [i] 0)))
      (= it 0)
      (while
        (< it maxRestart)
        (block
          (call compute_residual n x b r w)
          (= beta (call norm2 n r))
          (= rnorm beta)
          (cond (<= rnorm tol) (block break))
          (for i 0 (- n 1) 1 (block (= V [0 i] (/ (index i r) beta))))
          (= g [0] beta)
          (for j 1 m 1 (block (= g [j] 0)))
          (= jArn (- m 1))
          (for j
            0
            (- m 1)
            1
            (block
              (= jArn j)
              (for i 0 (- n 1) 1 (block (= w [i] 0)))
              (for k 0 (- n 1) 1 (block (= tmpv [k] (index [j k] V))))
              (call matvec n tmpv w)
              (for i
                0
                j
                1
                (block
                  (for k 0 (- n 1) 1 (block (= tmpv [k] (index [i k] V))))
                  (= hi (call dot n w tmpv))
                  (= H [i j] hi)
                  (for k 0 (- n 1) 1 (block (= w [k] (- (index k w) (* hi (index [i k] V))))))))
              (= hip1 (call norm2 n w))
              (= H [(+ j 1) j] hip1)
