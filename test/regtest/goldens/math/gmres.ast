                  (= H [(+ i 1) j] (+ (* (- (index i sn)) (index [i j] H)) (* (index i cs) (index [(+ i 1) j] H))))
                  (= H [i j] tmp)))
              (= denom
                (call sqrt (+ (* (index [j j] H) (index [j j] H)) (* (index [(+ j 1) j] H) (index [(+ j 1) j] H)))))
              (cond
                (!= denom 0)
                (block
                  (= cs [j] (/ (index [j j] H) denom))
                  (= sn [j] (/ (index [(+ j 1) j] H) denom)))
                (block
                  (= cs [j] 1)
                  (= sn [j] 0)))
              (= H [j j] (+ (* (index j cs) (index [j j] H)) (* (index j sn) (index [(+ j 1) j] H))))
              (= H [(+ j 1) j] 0)
              (= tmp (* (index j cs) (index j g)))
              (= g [(+ j 1)] (* (- (index j sn)) (index j g)))
              (= g [j] tmp)
              (= rnorm (index (+ j 1) g))
              (cond (< rnorm 0) (block (= rnorm (- rnorm))))
              (cond (<= rnorm tol) (block (= jArn j) break))))
          (for i 0 jArn 1 (block (= y [i] 0)))
          (for i
            jArn
            0
            (- 1)
            (block
              (= sum (index i g))
              (for k (+ i 1) jArn 1 (block (= sum (- sum (* (index [i k] H) (index k y))))))
              (cond (!= (index [i i] H) 0) (block (= y [i] (/ sum (index [i i] H)))) (block (= y [i] 0)))))
          (for k
            0
            (- n 1)
            1
            (block
              (= sum 0)
              (for i 0 jArn 1 (block (= sum (+ sum (* (index [i k] V) (index i y))))))
              (= x [k] (+ (index k x) sum))))
          (call compute_residual n x b r w)
          (= rnorm (call norm2 n r))
          (cond (<= rnorm tol) (block break))
          (= it (+ it 1))))
      (call compute_residual n x b r w)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (var vabs f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= vabs (index i r))
          (cond (< vabs 0) (block (= vabs (- vabs))))
          (= res_l2_sq (+ res_l2_sq (* (index i r) (index i r))))
          (cond (> vabs res_inf) (block (= res_inf vabs)))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "gmres: n=")
        (call output_int64 n 0)
        (call output_string ", m=")
        (call output_int64 m 0)
        (call output_string "\n"))
      (seq
