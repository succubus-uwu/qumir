(block
  (fun <main> void () ()
    (block
      (var Nx i64)
      (var Ny i64)
      (var Nz i64)
      (= Nx 8)
      (= Ny 8)
      (= Nz 8)
      (var pi f64)
      (= pi 3.14159)
      (var h f64)
      (var h2 f64)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (= h2 (* h h))
      (var lam f64)
      (var dt f64)
      (var T f64)
      (= lam 0.5)
      (= dt (* lam h2))
      (= T 0.1)
      (var nt i64)
      (= nt (call int (/ T dt)))
      (cond (< nt 1) (block (= nt 1)))
      (seq
        (var $$u_lbound3 i64)
        (var $$u_dimsize3 i64)
        (var $$u_mulacc3 i64)
        (= $$u_lbound3 0)
        (= $$u_dimsize3 (+ (- (- Nz 1) 0) 1))
        (= $$u_mulacc3 (* 1 $$u_dimsize3))
        (var $$u_lbound2 i64)
        (var $$u_dimsize2 i64)
        (var $$u_mulacc2 i64)
        (= $$u_lbound2 0)
        (= $$u_dimsize2 (+ (- (- Ny 1) 0) 1))
        (= $$u_mulacc2 (* (* 1 $$u_dimsize3) $$u_dimsize2))
        (var $$u_lbound1 i64)
        (var $$u_dimsize1 i64)
        (var $$u_mulacc1 i64)
        (= $$u_lbound1 0)
        (= $$u_dimsize1 (+ (- (- Nx 1) 0) 1))
        (= $$u_mulacc1 (* (* (* 1 $$u_dimsize3) $$u_dimsize2) $$u_dimsize1))
        (var $$u_lbound0 i64)
        (var $$u_dimsize0 i64)
        (var $$u_mulacc0 i64)
        (= $$u_lbound0 0)
        (= $$u_dimsize0 (+ (- nt 0) 1))
        (= $$u_mulacc0 (* (* (* (* 1 $$u_dimsize3) $$u_dimsize2) $$u_dimsize1) $$u_dimsize0))
        (var u <array f64 4>))
      (var i i64)
      (var j i64)
      (var k i64)
      (var n i64)
      (var it i64)
      (var maxIt i64)
      (var x f64)
      (var y f64)
      (var z f64)
      (var t f64)
      (var decay f64)
      (var uex f64)
      (var diff f64)
      (var err f64)
      (var rhs f64)
      (var newv f64)
      (var oldv f64)
      (var change f64)
      (var denom f64)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= u [0 i j k] (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))))))))
      (= maxIt 200)
      (= denom (+ 1 (* 6 lam)))
      (for n
        0
        (- nt 1)
        1
        (block
          (for i
            0
            (- Nx 1)
            1
            (block
              (for j 0 (- Ny 1) 1 (block (for k 0 (- Nz 1) 1 (block (= u [(+ n 1) i j k] (index [n i j k] u))))))))
          (for it
            0
            (- maxIt 1)
            1
            (block
              (= change 0)
              (for i
                1
                (- Nx 2)
                1
                (block
                  (for j
                    1
                    (- Ny 2)
                    1
                    (block
                      (for k
                        1
                        (- Nz 2)
                        1
                        (block
                          (= oldv (index [(+ n 1) i j k] u))
                          (= rhs (index [n i j k] u))
                          (= newv
                            (/ (+ rhs
                                (* lam
                                  (+ (+ (+ (+ (+ (index [(+ n 1) (+ i 1) j k] u) (index [(+ n 1) (- i 1) j k] u))
                                          (index [(+ n 1) i (+ j 1) k] u))
                                        (index [(+ n 1) i (- j 1) k] u))
                                      (index [(+ n 1) i j (+ k 1)] u))
                                    (index [(+ n 1) i j (- k 1)] u))))
                              denom))
                          (= u [(+ n 1) i j k] newv)
                          (= diff (let (($$value (- newv oldv))) (if (< $$value 0) (- $$value) $$value)))
                          (= change (let (($$left change) ($$right diff)) (if (> $$left $$right) $$left $$right)))))))))
              (cond (< change 1e-06) (block break))))))
      (= t (* (cast nt f64) dt))
      (= decay (call exp (* (* (* (- 3) pi) pi) t)))
      (= err 0)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= uex (* (* (* decay (call sin (* pi x))) (call sin (* pi y))) (call sin (* pi z))))
                  (= diff (let (($$value (- (index [nt i j k] u) uex))) (if (< $$value 0) (- $$value) $$value)))
                  (= err (let (($$left err) ($$right diff)) (if (> $$left $$right) $$left $$right)))))))))
      (seq
        (call output_string "Heat3D implicit (4D): N=")
        (call output_int64 Nx 0)
        (call output_string ", T=")
        (call output_double t 8 8)
        (call output_string ", dt=")
        (call output_double dt 8 8)
        (call output_string ", max|u-uex|=")
        (call output_double err 8 8)
        (call output_symbol (cast 10 char)))
      (cond (< err 0.01) (block (seq (call output_string "OK\n"))) (block (seq (call output_string "FAIL\n")))))))