(block
  (fun <main> ()
    (block
      (var Nx i64)
      (var Ny i64)
      (var Nz i64)
      (= Nx 8)
      (= Ny 8)
      (= Nz 8)
      (var pi f64)
      (= pi 3.1415926866674426)
      (var h f64)
      (var h2 f64)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (= h2 (* h h))
      (var lam f64)
      (var dt f64)
      (var T f64)
      (= lam 0.5)
      (= dt (* lam h2))
      (= T 0.10000000000000001)
      (var nt i64)
      (= nt (call int (/ T dt)))
      (if (< nt 1) (block (= nt 1)))
      (var u <array f64 4> [0 nt] [0 (- Nx 1)] [0 (- Ny 1)] [0 (- Nz 1)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var n i64)
      (var it i64)
      (var maxIt i64)
      (var x f64)
      (var y f64)
      (var z f64)
      (var t f64)
      (var decay f64)
      (var uex f64)
      (var diff f64)
      (var err f64)
      (var rhs f64)
      (var newv f64)
      (var oldv f64)
      (var change f64)
      (var denom f64)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= u [0 i j k] (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))))))))
      (= maxIt 200)
      (= denom (+ 1 (* 6 lam)))
      (for n
        0
        (- nt 1)
        1
        (block
          (for i
            0
            (- Nx 1)
            1
            (block
              (for j 0 (- Ny 1) 1 (block (for k 0 (- Nz 1) 1 (block (= u [(+ n 1) i j k] (index u [n i j k]))))))))
          (for it
            0
            (- maxIt 1)
            1
            (block
              (= change 0)
              (for i
                1
                (- Nx 2)
                1
                (block
                  (for j
                    1
                    (- Ny 2)
                    1
                    (block
                      (for k
                        1
                        (- Nz 2)
                        1
                        (block
                          (= oldv (index u [(+ n 1) i j k]))
                          (= rhs (index u [n i j k]))
                          (= newv
                            (/ (+ rhs
                                (* lam
                                  (+ (+ (+ (+ (+ (index u [(+ n 1) (+ i 1) j k]) (index u [(+ n 1) (- i 1) j k]))
                                          (index u [(+ n 1) i (+ j 1) k]))
                                        (index u [(+ n 1) i (- j 1) k]))
                                      (index u [(+ n 1) i j (+ k 1)]))
                                    (index u [(+ n 1) i j (- k 1)]))))
                              denom))
                          (= u [(+ n 1) i j k] newv)
                          (= diff (block (var $$value = (- newv oldv)) (if (< $$value 0) (- $$value) $$value)))
                          (= change
                            (block
                              (var $$left = change)
                              (var $$right = diff)
                              (if (> $$left $$right) $$left $$right)))))))))
              (if (< change 9.9999999999999995e-07) (block (cleanup-exit (break))))))))
      (= t (* (cast nt f64) dt))
      (= decay (call exp (* (* (* (- 3) pi) pi) t)))
      (= err 0)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= uex (* (* (* decay (call sin (* pi x))) (call sin (* pi y))) (call sin (* pi z))))
                  (= diff (block (var $$value = (- (index u [nt i j k]) uex)) (if (< $$value 0) (- $$value) $$value)))
                  (= err (block (var $$left = err) (var $$right = diff) (if (> $$left $$right) $$left $$right)))))))))
      (block
        (call output_string "Heat3D implicit (4D): N=")
        (call output_int64 Nx 0)
        (call output_string ", T=")
        (call output_double t 8 8)
        (call output_string ", dt=")
        (call output_double dt 8 8)
        (call output_string ", max|u-uex|=")
        (call output_double err 8 8)
        (call output_symbol (cast 10 char)))
      (if (< err 0.01) (block (block (call output_string "OK\n"))) (block (block (call output_string "FAIL\n"))))
      (cleanup-exit (return) (destroy u)))))