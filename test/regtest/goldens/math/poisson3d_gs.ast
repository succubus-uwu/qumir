(block
  (fun <main> ()
    (block
      (var Nx i64)
      (var Ny i64)
      (var Nz i64)
      (= Nx 8)
      (= Ny 8)
      (= Nz 8)
      (var pi f64)
      (= pi 3.1415926866674426)
      (var h f64)
      (= h (/ 1 (cast (- Nx 1) f64)))
      (var h2 f64)
      (= h2 (* h h))
      (var u <array f64 3> [0 (- Nx 1)] [0 (- Ny 1)] [0 (- Nz 1)])
      (var f <array f64 3> [0 (- Nx 1)] [0 (- Ny 1)] [0 (- Nz 1)])
      (var i i64)
      (var j i64)
      (var k i64)
      (var x f64)
      (var y f64)
      (var z f64)
      (var err f64)
      (var uex f64)
      (var diff f64)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= u [i j k] 0)
                  (= f [i j k] (* (* (* (* (* 3 pi) pi) (call sin (* pi x))) (call sin (* pi y))) (call sin (* pi z))))))))))
      (var it i64)
      (var iters i64)
      (= iters 1000)
      (var tol f64)
      (= tol 0.001)
      (for it
        0
        (- iters 1)
        1
        (block
          (for i
            1
            (- Nx 2)
            1
            (block
              (for j
                1
                (- Ny 2)
                1
                (block
                  (for k
                    1
                    (- Nz 2)
                    1
                    (block
                      (= u
                        [i
                          j
                          k]
                        (/ (+ (+ (+ (+ (+ (+ (index u [(+ i 1) j k]) (index u [(- i 1) j k])) (index u [i (+ j 1) k]))
                                  (index u [i (- j 1) k]))
                                (index u [i j (+ k 1)]))
                              (index u [i j (- k 1)]))
                            (* h2 (index f [i j k])))
                          6))))))))
          (= err 0)
          (for i
            0
            (- Nx 1)
            1
            (block
              (= x (* (cast i f64) h))
              (for j
                0
                (- Ny 1)
                1
                (block
                  (= y (* (cast j f64) h))
                  (for k
                    0
                    (- Nz 1)
                    1
                    (block
                      (= z (* (cast k f64) h))
                      (= uex (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))
                      (= diff (block (var $$value = (- (index u [i j k]) uex)) (if (< $$value 0) (- $$value) $$value)))
                      (= err (block (var $$left = err) (var $$right = diff) (if (> $$left $$right) $$left $$right)))))))))
          (if (< err tol) (block (cleanup-exit (break))))))
      (= err 0)
      (for i
        0
        (- Nx 1)
        1
        (block
          (= x (* (cast i f64) h))
          (for j
            0
            (- Ny 1)
            1
            (block
              (= y (* (cast j f64) h))
              (for k
                0
                (- Nz 1)
                1
                (block
                  (= z (* (cast k f64) h))
                  (= uex (* (* (call sin (* pi x)) (call sin (* pi y))) (call sin (* pi z))))
                  (= diff (block (var $$value = (- (index u [i j k]) uex)) (if (< $$value 0) (- $$value) $$value)))
                  (= err (block (var $$left = err) (var $$right = diff) (if (> $$left $$right) $$left $$right)))))))))
      (block
        (call output_string "Poisson3D-GS: N=")
        (call output_int64 Nx 0)
        (call output_string " max|u-uex|=")
        (call output_double err 8 8)
        (call output_symbol (cast 10 char)))
      (if (< err tol) (block (block (call output_string "OK\n"))) (block (block (call output_string "FAIL\n"))))
      (cleanup-exit (return) (destroy f) (destroy u)))))