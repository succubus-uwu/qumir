(block
  (fun main ()
    (block
      (var n i64)
      (var maxIter i64)
      (var tol f64)
      (= n 16)
      (= maxIter 500)
      (= tol 7.0918695992859933e-10)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array f64 1> [0 (- n 1)])
      (var p <array f64 1> [0 (- n 1)])
      (var Ap <array f64 1> [0 (- n 1)])
      (var i i64)
      (var it i64)
      (var rsold f64)
      (var rsnew f64)
      (var alpha f64)
      (var pAp f64)
      (var rnorm f64)
      (var vabs f64)
      (for i 0 (- n 1) 1 (block (= b [i] 1) (= x [i] 0)))
      (call compute_residual n x b r Ap)
      (for i 0 (- n 1) 1 (block (= p [i] (index r i))))
      (= rsold (call dot n r r))
      (= it 0)
      (while
        (< it maxIter)
        (block
          (call matvec n p Ap)
          (= pAp (call dot n p Ap))
          (if (== pAp 0) (block (cleanup-exit (break))))
          (= alpha (/ rsold pAp))
          (for i
            0
            (- n 1)
            1
            (block
              (= x [i] (+ (index x i) (* alpha (index p i))))
              (= r [i] (- (index r i) (* alpha (index Ap i))))))
          (= rnorm (call norm2 n r))
          (if (<= rnorm tol) (block (cleanup-exit (break))))
          (= rsnew (call dot n r r))
          (if
            (!= rsold 0)
            (block
              (var beta f64)
              (= beta (/ rsnew rsold))
              (for i 0 (- n 1) 1 (block (= p [i] (+ (index r i) (* beta (index p i)))))))
            (block
              (for i 0 (- n 1) 1 (block (= p [i] (index r i))))))
          (= rsold rsnew)
          (= it (+ it 1))))
      (call compute_residual n x b r Ap)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= vabs (index r i))
          (if (< vabs 0) (block (= vabs (- vabs))))
          (= res_l2_sq (+ res_l2_sq (* (index r i) (index r i))))
          (if (> vabs res_inf) (block (= res_inf vabs)))))
      (= res_l2 (call sqrt res_l2_sq))
      (block
        (call output_string "cg: n=")
        (call output_int64 n 0)
        (call output_string ", maxIter=")
        (call output_int64 maxIter 0)
        (call output_string "\n"))
      (block
        (call output_string "iters=")
        (call output_int64 it 0)
        (call output_string "\n"))
      (block
        (call output_string "||r||_2= ")
        (call output_double res_l2 8 8)
        (call output_string "\n"))
      (block
        (call output_string "||r||_inf= ")
        (call output_double res_inf 8 8)
        (call output_string "\n"))
      (cleanup-exit (return) (destroy Ap) (destroy p) (destroy r) (destroy b) (destroy x))))
  (fun matvec ((var n i64)
      (var v <array f64 1> [0 (- n 1)])
      (var w <array <f64 (mutable)> 1> [0 (- n 1)]))
    (block
      (var i i64)
      (var j i64)
      (var sum f64)
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (/ 1 (+ (cast (+ i j) f64) 1)) (index v j))))))
          (= w [i] sum)))
      (cleanup-exit (return))))
  (fun norm2 ((var n i64)
      (var v <array f64 1> [0 (- n 1)])) -> f64
    (block
      (var знач f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index v i) (index v i))))))
      (= знач (call sqrt sum))
      (cleanup-exit (return знач))))
  (fun dot ((var n i64)
      (var a <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])) -> f64
    (block
      (var знач f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index a i) (index b i))))))
      (= знач sum)
      (cleanup-exit (return знач))))
  (fun compute_residual ((var n i64)
      (var x <array f64 1> [0 (- n 1)])
      (var b <array f64 1> [0 (- n 1)])
      (var r <array <f64 (mutable)> 1> [0 (- n 1)])
      (var w <array f64 1> [0 (- n 1)]))
    (block
      (var i i64)
      (call matvec n x w)
      (for i 0 (- n 1) 1 (block (= r [i] (- (index b i) (index w i)))))
      (cleanup-exit (return)))))