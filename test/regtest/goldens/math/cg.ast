(block
  (fun main void () ()
    (block
      (var n i64)
      (var maxIter i64)
      (var tol f64)
      (= n 16)
      (= maxIter 500)
      (= tol 7.09187e-10)
      (seq
        (var $$x_lbound0 i64)
        (var $$x_dimsize0 i64)
        (var $$x_mulacc0 i64)
        (= $$x_lbound0 0)
        (= $$x_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$x_mulacc0 (* 1 $$x_dimsize0))
        (var x <array f64 1>))
      (seq
        (var $$b_lbound0 i64)
        (var $$b_dimsize0 i64)
        (var $$b_mulacc0 i64)
        (= $$b_lbound0 0)
        (= $$b_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$b_mulacc0 (* 1 $$b_dimsize0))
        (var b <array f64 1>))
      (seq
        (var $$r_lbound0 i64)
        (var $$r_dimsize0 i64)
        (var $$r_mulacc0 i64)
        (= $$r_lbound0 0)
        (= $$r_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$r_mulacc0 (* 1 $$r_dimsize0))
        (var r <array f64 1>))
      (seq
        (var $$p_lbound0 i64)
        (var $$p_dimsize0 i64)
        (var $$p_mulacc0 i64)
        (= $$p_lbound0 0)
        (= $$p_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$p_mulacc0 (* 1 $$p_dimsize0))
        (var p <array f64 1>))
      (seq
        (var $$Ap_lbound0 i64)
        (var $$Ap_dimsize0 i64)
        (var $$Ap_mulacc0 i64)
        (= $$Ap_lbound0 0)
        (= $$Ap_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$Ap_mulacc0 (* 1 $$Ap_dimsize0))
        (var Ap <array f64 1>))
      (var i i64)
      (var it i64)
      (var rsold f64)
      (var rsnew f64)
      (var alpha f64)
      (var pAp f64)
      (var rnorm f64)
      (var vabs f64)
      (for i 0 (- n 1) 1 (block (= b [i] 1) (= x [i] 0)))
      (call compute_residual n x b r Ap)
      (for i 0 (- n 1) 1 (block (= p [i] (index i r))))
      (= rsold (call dot n r r))
      (= it 0)
      (while
        (< it maxIter)
        (block
          (call matvec n p Ap)
          (= pAp (call dot n p Ap))
          (cond (== pAp 0) (block break))
          (= alpha (/ rsold pAp))
          (for i
            0
            (- n 1)
            1
            (block
              (= x [i] (+ (index i x) (* alpha (index i p))))
              (= r [i] (- (index i r) (* alpha (index i Ap))))))
          (= rnorm (call norm2 n r))
          (cond (<= rnorm tol) (block break))
          (= rsnew (call dot n r r))
          (cond
            (!= rsold 0)
            (block
              (var beta f64)
              (= beta (/ rsnew rsold))
              (for i 0 (- n 1) 1 (block (= p [i] (+ (index i r) (* beta (index i p)))))))
            (block
              (for i 0 (- n 1) 1 (block (= p [i] (index i r))))))
          (= rsold rsnew)
          (= it (+ it 1))))
      (call compute_residual n x b r Ap)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= vabs (index i r))
          (cond (< vabs 0) (block (= vabs (- vabs))))
          (= res_l2_sq (+ res_l2_sq (* (index i r) (index i r))))
          (cond (> vabs res_inf) (block (= res_inf vabs)))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "cg: n=")
        (call output_int64 n 0)
        (call output_string ", maxIter=")
        (call output_int64 maxIter 0)
        (call output_string "\n"))
      (seq
        (call output_string "iters=")
        (call output_int64 it 0)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_2= ")
        (call output_double res_l2 8 8)
        (call output_string "\n"))
      (seq
        (call output_string "||r||_inf= ")
        (call output_double res_inf 8 8)
        (call output_string "\n"))))
  (fun matvec void ((var n i64)
      (var v <array f64 1>)
      (var w <array f64 1>)) ()
    (block
      (var $$v_lbound0 i64)
      (var $$v_dimsize0 i64)
      (var $$v_mulacc0 i64)
      (= $$v_lbound0 0)
      (= $$v_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$v_mulacc0 (* 1 $$v_dimsize0))
      (var $$w_lbound0 i64)
      (var $$w_dimsize0 i64)
      (var $$w_mulacc0 i64)
      (= $$w_lbound0 0)
      (= $$w_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$w_mulacc0 (* 1 $$w_dimsize0))
      (var i i64)
      (var j i64)
      (var sum f64)
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (/ 1 (+ (cast (+ i j) f64) 1)) (index j v))))))
          (= w [i] sum)))))
  (fun norm2 f64 ((var n i64)
      (var v <array f64 1>)) ()
    (block
      (var $$v_lbound0 i64)
      (var $$v_dimsize0 i64)
      (var $$v_mulacc0 i64)
      (= $$v_lbound0 0)
      (= $$v_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$v_mulacc0 (* 1 $$v_dimsize0))
      (var $$return f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index i v) (index i v))))))
      (= $$return (call sqrt sum))))
  (fun dot f64 ((var n i64)
      (var a <array f64 1>)
      (var b <array f64 1>)) ()
    (block
      (var $$a_lbound0 i64)
      (var $$a_dimsize0 i64)
      (var $$a_mulacc0 i64)
      (= $$a_lbound0 0)
      (= $$a_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$a_mulacc0 (* 1 $$a_dimsize0))
      (var $$b_lbound0 i64)
      (var $$b_dimsize0 i64)
      (var $$b_mulacc0 i64)
      (= $$b_lbound0 0)
      (= $$b_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$b_mulacc0 (* 1 $$b_dimsize0))
      (var $$return f64)
      (var i i64)
      (var sum f64)
      (= sum 0)
      (for i 0 (- n 1) 1 (block (= sum (+ sum (* (index i a) (index i b))))))
      (= $$return sum)))
  (fun compute_residual void ((var n i64)
      (var x <array f64 1>)
      (var b <array f64 1>)
      (var r <array f64 1>)
      (var w <array f64 1>)) ()
    (block
      (var $$x_lbound0 i64)
      (var $$x_dimsize0 i64)
      (var $$x_mulacc0 i64)
      (= $$x_lbound0 0)
      (= $$x_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$x_mulacc0 (* 1 $$x_dimsize0))
      (var $$b_lbound0 i64)
      (var $$b_dimsize0 i64)
      (var $$b_mulacc0 i64)
      (= $$b_lbound0 0)
      (= $$b_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$b_mulacc0 (* 1 $$b_dimsize0))
      (var $$r_lbound0 i64)
      (var $$r_dimsize0 i64)
      (var $$r_mulacc0 i64)
      (= $$r_lbound0 0)
      (= $$r_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$r_mulacc0 (* 1 $$r_dimsize0))
      (var $$w_lbound0 i64)
      (var $$w_dimsize0 i64)
      (var $$w_mulacc0 i64)
      (= $$w_lbound0 0)
      (= $$w_dimsize0 (+ (- (- n 1) 0) 1))
      (= $$w_mulacc0 (* 1 $$w_dimsize0))
      (var i i64)
      (call matvec n x w)
      (for i 0 (- n 1) 1 (block (= r [i] (- (index i b) (index i w))))))))