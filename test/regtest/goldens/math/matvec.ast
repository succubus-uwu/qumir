(block
  (fun main void () ()
    (block
      (var n i64)
      (var i i64)
      (var j i64)
      (= n 256)
      (seq
        (var $$A_lbound1 i64)
        (var $$A_dimsize1 i64)
        (var $$A_mulacc1 i64)
        (= $$A_lbound1 0)
        (= $$A_dimsize1 (+ (- (- n 1) 0) 1))
        (= $$A_mulacc1 (* 1 $$A_dimsize1))
        (var $$A_lbound0 i64)
        (var $$A_dimsize0 i64)
        (var $$A_mulacc0 i64)
        (= $$A_lbound0 0)
        (= $$A_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$A_mulacc0 (* (* 1 $$A_dimsize1) $$A_dimsize0))
        (var A <array f64 2>))
      (seq
        (var $$x_lbound0 i64)
        (var $$x_dimsize0 i64)
        (var $$x_mulacc0 i64)
        (= $$x_lbound0 0)
        (= $$x_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$x_mulacc0 (* 1 $$x_dimsize0))
        (var x <array f64 1>))
      (seq
        (var $$y_lbound0 i64)
        (var $$y_dimsize0 i64)
        (var $$y_mulacc0 i64)
        (= $$y_lbound0 0)
        (= $$y_dimsize0 (+ (- (- n 1) 0) 1))
        (= $$y_mulacc0 (* 1 $$y_dimsize0))
        (var y <array f64 1>))
      (var sum f64)
      (var absv f64)
      (var res_l2_sq f64)
      (var res_l2 f64)
      (var res_inf f64)
      (var err f64)
      (for i
        0
        (- n 1)
        1
        (block
          (for j 0 (- n 1) 1 (block (cond (<= j i) (block (= A [i j] 1)) (block (= A [i j] 0)))))
          (= x [i] 1)))
      (for i
        0
        (- n 1)
        1
        (block
          (= sum 0)
          (for j 0 (- n 1) 1 (block (= sum (+ sum (* (index [i j] A) (index j x))))))
          (= y [i] sum)))
      (= res_l2_sq 0)
      (= res_inf 0)
      (for i
        0
        (- n 1)
        1
        (block
          (= err (- (index i y) (+ (cast i f64) 1)))
          (= absv err)
          (cond (< absv 0) (block (= absv (- absv))))
          (= res_l2_sq (+ res_l2_sq (* err err)))
          (cond (> absv res_inf) (block (= res_inf absv)))))
      (= res_l2 (call sqrt res_l2_sq))
      (seq
        (call output_string "matvec: ||e||_2^2 = ")
        (call output_double res_l2_sq 0 -1)
        (call output_string "\n"))
      (seq
        (call output_string "matvec: ||e||_2    = ")
        (call output_double res_l2 0 -1)
        (call output_string "\n"))
      (seq
        (call output_string "matvec: ||e||_inf  = ")
        (call output_double res_inf 0 -1)
        (call output_string "\n")))))